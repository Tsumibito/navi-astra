---
interface Props { locale?: 'ru' | 'ua' | 'en' }
const { locale = 'ru' } = Astro.props;
const t = {
  ru: { kicker: 'Временно недоступно', title: 'Курс временно недоступен для продажи', body: 'Когда продажи вновь откроются, мы вам сообщим. Оставьте e-mail, чтобы подписаться на рассылку.', email: 'E-mail', consent: 'Согласен получать рассылку и принимаю', privacy: 'политику конфиденциальности', close: 'Закрыть', button: 'Подписаться', sending: 'Отправляем…', success: 'Вы подписаны. Мы сообщим, как только продажи откроются.', error: 'Не удалось отправить. Попробуйте ещё раз.' },
  ua: { kicker: 'Тимчасово недоступно', title: 'Курс тимчасово недоступний для продажу', body: 'Коли продажі знову відкриються, ми вам повідомимо. Залиште e-mail, щоб підписатися на розсилку.', email: 'E-mail', consent: 'Погоджуюся отримувати розсилку та приймаю', privacy: 'політику конфіденційності', close: 'Закрити', button: 'Підписатися', sending: 'Надсилаємо…', success: 'Ви підписані. Ми повідомимо, щойно продажі відкриються.', error: 'Не вдалося надіслати. Спробуйте ще раз.' },
  en: { kicker: 'Temporarily unavailable', title: 'The course is temporarily unavailable for purchase', body: 'We will notify you when sales reopen. Leave your e-mail to subscribe to the newsletter.', email: 'E-mail', consent: 'I agree to receive the newsletter and accept the', privacy: 'privacy policy', close: 'Close', button: 'Subscribe', sending: 'Sending…', success: 'You are subscribed. We will notify you once sales reopen.', error: 'Could not send. Please try again.' },
}[locale];
const privacyHref = `/${locale}/privacy-policy`;
---
<dialog class="service-modal" id="course-unavailable-modal" aria-modal="true" aria-labelledby="course-unavailable-title">
  <section class="service-modal__card">
    <button class="service-modal__close" type="button" data-close-course-unavailable aria-label={t.close}>×</button>
    <form class="service-form" data-course-unavailable-form>
      <div class="form-heading form-wide">
        <p class="eyebrow">{t.kicker}</p>
        <h2 id="course-unavailable-title">{t.title}</h2>
        <p>{t.body}</p>
      </div>
      <div class="form-grid">
        <label class="form-wide"><span>{t.email}</span><input name="email" type="email" autocomplete="email" required /></label>
        <input class="form-trap" name="company" tabindex="-1" autocomplete="off" />
        <label class="form-consent form-wide"><input name="consent" type="checkbox" required /><span>{t.consent} <a href={privacyHref}>{t.privacy}</a></span></label>
        <div class="form-action form-wide"><button type="submit">{t.button}<span aria-hidden="true">→</span></button><p id="course-unavailable-status" data-form-status aria-live="polite"></p></div>
      </div>
    </form>
  </section>
</dialog>
<script define:vars={{ t, locale }}>
  const modal = document.getElementById('course-unavailable-modal');
  if (modal) {
    const closeModal = () => {
      if (!modal.open) return;
      modal.classList.remove('is-open');
      setTimeout(() => modal.close(), 220);
    };
    modal.querySelector('[data-close-course-unavailable]')?.addEventListener('click', (event) => { event.preventDefault(); closeModal(); });
    modal.addEventListener('cancel', (event) => { event.preventDefault(); closeModal(); });
    modal.addEventListener('click', (event) => {
      const rect = modal.getBoundingClientRect();
      if (event.clientX < rect.left || event.clientX > rect.right || event.clientY < rect.top || event.clientY > rect.bottom) closeModal();
    });

    const form = modal.querySelector('[data-course-unavailable-form]');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector('button[type="submit"]');
      const status = form.querySelector('[data-form-status]');
      button.disabled = true;
      status.textContent = t.sending;
      try {
        const data = new FormData(form);
        const response = await fetch('https://payload.navi.training/api/public/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            kind: 'newsletter',
            email: data.get('email'),
            company: data.get('company'),
            consent: true,
            locale,
            sourceUrl: location.href,
            utm: location.search.slice(1)
          })
        });
        if (!response.ok) throw new Error();
        form.innerHTML = `<div class="form-success"><span>✓</span><h2>${t.success}</h2></div>`;
      } catch {
        status.textContent = t.error;
        button.disabled = false;
      }
    });
  }
</script>
