---
/**
 * Reusable FAQ accordion in the original Webstudio style: a white rounded
 * card with generously padded rows separated by 2px lines.
 * Props:
 *   items — Array<{ q: string; a: string }>
 */
interface Props {
  items: Array<{ q: string; a: string }>;
}
const { items } = Astro.props;
---
{items.length > 0 && (
  <div class="navi-faq">
    {items.map((item) => (
      <details class="navi-faq__item">
        <summary>{item.q}<span class="navi-faq__marker" aria-hidden="true"></span></summary>
        <div class="navi-faq__answer"><p>{item.a}</p></div>
      </details>
    ))}
  </div>
)}
<style is:global>
  .navi-faq{box-sizing:border-box;max-width:932px;margin:60px auto;background:#fff;border:2px solid #dbdbdb;border-radius:30px;overflow:hidden}
  .navi-faq__item{border-top:2px solid #dbdbdb}
  .navi-faq__item:first-child{border-top:0}
  .navi-faq__item summary{display:flex;align-items:center;justify-content:space-between;gap:24px;padding:clamp(28px,4.3vw,62px) clamp(20px,4.2vw,60px);font:400 clamp(16px,1.7vw,24px)/1.25 var(--font-neo,Arial,sans-serif);color:var(--ds-ink,#073746);cursor:pointer;list-style:none}
  .navi-faq__item summary::-webkit-details-marker{display:none}
  .navi-faq__marker{flex:none;width:14px;height:14px;border-right:2px solid #9aa9ae;border-bottom:2px solid #9aa9ae;transform:rotate(45deg) translateY(-4px);transition:transform .2s ease}
  .navi-faq__item[open] .navi-faq__marker{transform:rotate(225deg) translateY(-2px)}
  .navi-faq__answer{padding:0 clamp(20px,4.2vw,60px) clamp(24px,3.4vw,48px)}
  .navi-faq__answer p{margin:0;font-size:clamp(15px,1.25vw,18px);line-height:1.6;color:#3f5b64}
  @media (max-width: 640px){.navi-faq{margin:36px auto;border-radius:20px}}
</style>
