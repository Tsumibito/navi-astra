---
interface Props { locale?: 'ru' | 'ua' | 'en' | 'fr' }
const { locale = 'ru' } = Astro.props as Props;

const links = {
  ru: {
    columns: [
      {
        title: 'Компания',
        items: [
          { label: 'О нас', href: '/' },
          { label: 'Яхтенная школа', href: '/ru/sailing-school' },
          { label: 'Чартер', href: '/ru/charter' },
          { label: 'Блог', href: '/ru/blog' },
        ],
      },
      {
        title: 'Инфо',
        items: [
          { label: 'Теги', href: '/ru/tags' },
          { label: 'Privacy Policy', href: '/ru/privacy-policy' },
          { label: 'Cookie Policy', href: '/ru/cookie-policy' },
          { label: 'ISSA', href: 'https://issa-schools.org/' },
        ],
      },
    ],
  },
  ua: {
    columns: [
      {
        title: 'Компанія',
        items: [
          { label: 'Про нас', href: '/ua/' },
          { label: 'Яхтена школа', href: '/ua/sailing-school' },
          { label: 'Чартер', href: '/ua/charter' },
          { label: 'Блог', href: '/ua/blog' },
        ],
      },
      {
        title: 'Інфо',
        items: [
          { label: 'Теги', href: '/ua/tags' },
          { label: 'Політика конфіденційності', href: '/ua/privacy-policy' },
          { label: 'Cookie Policy', href: '/ua/cookie-policy' },
          { label: 'ISSA', href: 'https://issa-schools.org/' },
        ],
      },
    ],
  },
  en: {
    columns: [
      {
        title: 'Company',
        items: [
          { label: 'About', href: '/en/' },
          { label: 'Sailing School', href: '/en/sailing-school' },
          { label: 'Charter', href: '/en/charter' },
          { label: 'Blog', href: '/en/blog' },
        ],
      },
      {
        title: 'Info',
        items: [
          { label: 'Tags', href: '/en/tags' },
          { label: 'Privacy Policy', href: '/en/privacy-policy' },
          { label: 'Cookie Policy', href: '/en/cookie-policy' },
          { label: 'ISSA', href: 'https://issa-schools.org/' },
        ],
      },
    ],
  },
  fr: {
    columns: [
      {
        title: 'Entreprise',
        items: [
          { label: 'À propos', href: '/fr/' },
          { label: 'École de voile', href: '/fr/sailing-school' },
          { label: 'Charter', href: '/fr/charter' },
          { label: 'Blog', href: '/fr/blog' },
        ],
      },
      {
        title: 'Infos',
        items: [
          { label: 'Tags', href: '/fr/tags' },
          { label: 'Politique de confidentialité', href: '/fr/privacy-policy' },
          { label: 'Politique des cookies', href: '/fr/cookie-policy' },
          { label: 'ISSA', href: 'https://issa-schools.org/' },
        ],
      },
    ],
  },
} as const;

const t = links[locale] ?? links.en;
const homeHref = locale === 'ru' ? '/' : `/${locale}/`;
---
<footer class="text-white py-8 px-4 md:px-8 lg:px-16 xl:px-32 2xl:px-64" style="background-color: rgb(43, 42, 48);">
  <div class="mx-auto max-w-7xl grid grid-cols-1 md:grid-cols-4 gap-8 items-start place-items-center md:place-items-stretch">
    <!-- Логотип -->
    <div class="flex items-center md:justify-start">
      <a href={homeHref} class="inline-block" aria-label="Go to homepage">
        <img src="/navi_logo_w.avif" alt="Navi.training" class="h-[6.4rem] md:h-32 w-auto" />
      </a>
    </div>
    <!-- Ссылки -->
    <nav class="md:col-span-2 flex flex-col md:flex-row flex-wrap items-center justify-center gap-x-6 gap-y-2 text-center">
      <a href="/" class="hover:text-blue-400 transition-colors">О нас</a>
      <a href="/ru/sailing-school" class="hover:text-blue-400 transition-colors">Яхтенная школа</a>
      <a href="/ru/blog" class="hover:text-blue-400 transition-colors">Блог</a>
      <a href="/ru/tags" class="hover:text-blue-400 transition-colors">Теги</a>
      <a href="/ru/charter" class="hover:text-blue-400 transition-colors">Чартер</a>
      <a href="https://issa-schools.org/" class="hover:text-blue-400 transition-colors">ISSA</a>
    </nav>
    <!-- Социальные иконки -->
    <div class="flex flex-row flex-wrap items-center justify-center md:justify-end gap-3">
      <a href="https://t.me/navi_training" class="group" target="_blank" rel="noopener" aria-label="Telegram">
        <span class="inline-flex items-center justify-center rounded-full bg-gray-700/80 group-hover:bg-gray-600 transition-colors w-10 h-10">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.1117 4.49449C23.4296 2.94472 21.9074 1.65683 20.4317 2.227L2.3425 9.21601C0.694517 9.85273 0.621087 12.1572 2.22518 12.8975L6.1645 14.7157L8.03849 21.2746C8.13583 21.6153 8.40618 21.8791 8.74917 21.968C9.09216 22.0568 9.45658 21.9576 9.70712 21.707L12.5938 18.8203L16.6375 21.8531C17.8113 22.7334 19.5019 22.0922 19.7967 20.6549L23.1117 4.49449ZM3.0633 11.0816L21.1525 4.0926L17.8375 20.2531L13.1 16.6999C12.7019 16.4013 12.1448 16.4409 11.7929 16.7928L10.5565 18.0292L10.928 15.9861L18.2071 8.70703C18.5614 8.35278 18.5988 7.79106 18.2947 7.39293C17.9906 6.99479 17.4389 6.88312 17.0039 7.13168L6.95124 12.876L3.0633 11.0816ZM8.17695 14.4791L8.78333 16.6015L9.01614 15.321C9.05253 15.1209 9.14908 14.9366 9.29291 14.7928L11.5128 12.573L8.17695 14.4791Z"/></svg>
        </span>
      </a>
      <a href="https://www.facebook.com/navi.training" class="group" target="_blank" rel="noopener" aria-label="Facebook">
        <span class="inline-flex items-center justify-center rounded-full bg-gray-700/80 group-hover:bg-gray-600 transition-colors w-10 h-10">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12.0611C22 6.50451 17.5229 2 12 2C6.47715 2 2 6.50451 2 12.0611C2 17.0828 5.65684 21.2452 10.4375 22V14.9694H7.89844V12.0611H10.4375V9.84452C10.4375 7.32296 11.9305 5.93012 14.2146 5.93012C15.3088 5.93012 16.4531 6.12663 16.4531 6.12663V8.60261H15.1922C13.95 8.60261 13.5625 9.37822 13.5625 10.1739V12.0611H16.3359L15.8926 14.9694H13.5625V22C18.3432 21.2452 22 17.083 22 12.0611Z"/></svg>
        </span>
      </a>
      <a href="https://www.instagram.com/navi.training?igsh=MXRwaG14d3dzNjJrYw%3D%3D&utm_source=qr" class="group" target="_blank" rel="noopener" aria-label="Instagram">
        <span class="inline-flex items-center justify-center rounded-full bg-gray-700/80 group-hover:bg-gray-600 transition-colors w-10 h-10">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 .001 10.001A5 5 0 0 0 12 7zm6-1.25a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5zM12 9.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5z"/>
          </svg>
        </span>
      </a>
      <a href="https://linkedin.com/company/navi-training" class="group" target="_blank" rel="noopener" aria-label="LinkedIn">
        <span class="inline-flex items-center justify-center rounded-full bg-gray-700/80 group-hover:bg-gray-600 transition-colors w-10 h-10">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.61 4.08 5.5 2.99 5.5S1 4.61 1 3.5 1.9 1.5 2.99 1.5 4.98 2.39 4.98 3.5zM1.5 8.5h3v12h-3v-12zm7 0h2.88v1.63h.04c.4-.76 1.37-1.56 2.82-1.56 3.01 0 3.57 1.98 3.57 4.55V20.5h-3v-5.62c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96v5.72h-3v-12z"/>
          </svg>
        </span>
      </a>
      <a href="https://www.youtube.com/channel/UCNTYfzMJ05AUqYXN1mWdLcA" class="group" target="_blank" rel="noopener" aria-label="YouTube">
        <span class="inline-flex items-center justify-center rounded-full bg-gray-700/80 group-hover:bg-gray-600 transition-colors w-10 h-10">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.5 7.5a3.5 3.5 0 0 0-2.46-2.48C18.8 4.5 12 4.5 12 4.5s-6.8 0-9.04.52A3.5 3.5 0 0 0 .5 7.5 36.8 36.8 0 0 0 0 12a36.8 36.8 0 0 0 .5 4.5 3.5 3.5 0 0 0 2.46 2.48C5.2 19.5 12 19.5 12 19.5s6.8 0 9.04-.52A3.5 3.5 0 0 0 23.5 16.5 36.8 36.8 0 0 0 24 12a36.8 36.8 0 0 0-.5-4.5ZM9.75 15.02V8.98L15.5 12l-5.75 3.02Z"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
  <!-- Копирайт -->
  <div class="mt-8 mx-auto max-w-7xl text-gray-400 text-sm border-top border-t border-gray-700 pt-4">
    <div class="mx-auto max-w-[60rem] grid grid-cols-1 sm:grid-cols-2 gap-6 items-center">
      <div class="text-center sm:text-left leading-relaxed">
        <div>© 2023 MON NAVI</div>
        <div><em>5 Rue François Hennebique, 17140 Lagord</em>, France.</div>
        <div>All rights reserved.</div>
      </div>
      <div class="text-center sm:text-right">
        <div class="flex flex-wrap items-center justify-center gap-3 whitespace-normal">
          <a href="/ru/privacy-policy" class="hover:text-blue-400 transition-colors">Privacy Policy</a>
          <span>•</span>
          <a href="/ru/cookie-policy" class="hover:text-blue-400 transition-colors">Cookie Policy</a>
          <span>•</span>
          <a href="#" onclick="zaraz.consent.modal = true; return false;" class="hover:text-blue-400 transition-colors">Open Consent Modal</a>
        </div>
      </div>
    </div>
  </div>
</footer>
