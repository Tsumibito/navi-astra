---
interface Props { locale?: 'ru' | 'ua' | 'en' | 'fr' }
const { locale = 'ru' } = Astro.props as Props;
const prefix = `/${locale}`;
const home = locale === 'ru' ? '/' : `/${locale}/home`;
const copy = {
  ru: { travel: 'Путешествия', charter: 'Аренда яхт', routes: 'Маршруты', explore: 'Исследовать', blog: 'Блог', encyclopedia: 'Яхтенная энциклопедия', school: 'Яхтенная школа', slogan: 'От берега к новому горизонту.', action: 'Спланировать путешествие', port: 'Базовый порт' },
  ua: { travel: 'Подорожі', charter: 'Оренда яхт', routes: 'Маршрути', explore: 'Досліджувати', blog: 'Блог', encyclopedia: 'Яхтова енциклопедія', school: 'Яхтова школа', slogan: 'Від берега до нового горизонту.', action: 'Спланувати подорож', port: 'Базовий порт' },
  en: { travel: 'Yacht travel', charter: 'Yacht charter', routes: 'Routes', explore: 'Explore', blog: 'Journal', encyclopedia: 'Sailing encyclopedia', school: 'Sailing school', slogan: 'From shore to a new horizon.', action: 'Plan a voyage', port: 'Home port' },
};
const t = copy[locale] || copy.en;
---
<footer class="astro-footer">
  <div class="astro-footer__intro">
    <a href={home} aria-label="Navi.training"><img src="/navi_logo_w.avif" alt="Navi.training" /></a>
    <p>NAVI.TRAINING</p><h2>{t.slogan}</h2><a class="astro-footer__action" href={`${prefix}/charter`}>{t.action}</a>
  </div>
  <nav><strong>{t.travel}</strong><a href={`${prefix}/charter`}>{t.charter}</a><a href={`${prefix}/tags/sailing-routes`}>{t.routes}</a></nav>
  <nav><strong>{t.explore}</strong><a href={`${prefix}/blog`}>{t.blog}</a><a href={`${prefix}/encyclopedia`}>{t.encyclopedia}</a><a href={`${prefix}/sailing-school`}>{t.school}</a></nav>
  <div class="astro-footer__port"><strong>{t.port}</strong><b>La Rochelle, France</b><span>46.1603° N · 1.1511° W</span><address>5 Rue François Hennebique<br/>17140 Lagord, France</address></div>
  <div class="astro-footer__bottom">© MON NAVI</div>
</footer>
<style>
  .astro-footer{display:grid;grid-template-columns:1.3fr .7fr .7fr 1fr;gap:42px;padding:64px max(24px,calc((100vw - 1180px)/2)) 28px;color:#fff;background:#073746;border-top:4px solid #d97706}.astro-footer a{color:#fff;text-decoration:none}.astro-footer__intro img{width:140px;height:auto}.astro-footer__intro p,.astro-footer nav strong,.astro-footer__port>strong{display:block;margin:18px 0 12px;color:#9fc0c7;font:700 11px/1.3 Arial,sans-serif;letter-spacing:.16em;text-transform:uppercase}.astro-footer h2{max-width:12ch;margin:0 0 24px;font:400 38px/1.04 'Tenor Sans',sans-serif}.astro-footer__action{display:inline-block;padding-bottom:5px;border-bottom:2px solid #d97706;font-weight:700}.astro-footer nav{display:flex;flex-direction:column;gap:12px}.astro-footer__port{display:flex;flex-direction:column;gap:12px}.astro-footer__port b{font-size:18px}.astro-footer__port span{color:#d97706;font-weight:700}.astro-footer address{color:#c9dadd;font-style:normal;line-height:1.5}.astro-footer__bottom{grid-column:1/-1;padding-top:22px;border-top:1px solid rgba(255,255,255,.14);color:#9fc0c7;font-size:11px}@media(max-width:800px){.astro-footer{grid-template-columns:1fr 1fr}.astro-footer__intro,.astro-footer__port{grid-column:1/-1}}@media(max-width:480px){.astro-footer{grid-template-columns:1fr}.astro-footer__intro,.astro-footer__port{grid-column:auto}}
</style>
