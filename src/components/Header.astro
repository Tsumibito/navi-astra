---
interface Props { locale?: 'ru' | 'ua' | 'en' | 'fr'; languageHrefs?: Partial<Record<'ru' | 'ua' | 'en', string>> }
const { locale = 'ru', languageHrefs = {} } = Astro.props as Props;
const prefix = `/${locale}`;
const home = locale === 'ru' ? '/' : `/${locale}/home`;
const copy = {
  ru: { home: 'Главная', travel: 'Путешествия', charter: 'Аренда яхт', routes: 'Маршруты', regions: 'Регионы плавания', blog: 'Блог', encyclopedia: 'Яхтенная энциклопедия', about: 'О нас', team: 'Команда', contacts: 'Контакты', menu: 'Открыть меню' },
  ua: { home: 'Головна', travel: 'Подорожі', charter: 'Оренда яхт', routes: 'Маршрути', regions: 'Регіони плавання', blog: 'Блог', encyclopedia: 'Яхтова енциклопедія', about: 'Про нас', team: 'Команда', contacts: 'Контакти', menu: 'Відкрити меню' },
  en: { home: 'Home', travel: 'Yacht travel', charter: 'Yacht charter', routes: 'Routes', regions: 'Sailing regions', blog: 'Journal', encyclopedia: 'Sailing encyclopedia', about: 'About', team: 'Team', contacts: 'Contacts', menu: 'Open menu' },
};
const t = copy[locale as keyof typeof copy] || copy.en;
const langs = ['ru', 'ua', 'en'] as const;
---
<header class="site-header">
  <a class="site-header__brand" href={home} aria-label="Navi.training">
    <img src="/navi_training_logo_c1.avif" alt="Navi.training" width="210" height="48" />
  </a>
  <nav class="site-header__nav" aria-label="Main navigation">
    <a href={home}>{t.home}</a>
    <details><summary>{t.travel}</summary><div class="site-header__submenu"><a href={`${prefix}/charter`}>{t.charter}</a><a href={`${prefix}/tags/sailing-routes`}>{t.routes}</a><a href={`${prefix}/tags/sailing-regions`}>{t.regions}</a></div></details>
    <a href={`${prefix}/charter`}>{t.charter}</a>
    <a href={`${prefix}/blog`}>{t.blog}</a>
    <a href={`${prefix}/encyclopedia`}>{t.encyclopedia}</a>
    <details><summary>{t.about}</summary><div class="site-header__submenu"><a href={`${prefix}/team`}>{t.team}</a><a href="mailto:alex@navi.training">{t.contacts}</a></div></details>
  </nav>
  <div class="site-header__actions">
    <details class="site-header__languages">
      <summary>{locale.toUpperCase()}</summary>
      <div>{langs.map((lang) => <a href={languageHrefs[lang] ?? (lang === 'ru' ? '/' : `/${lang}/home`)} hreflang={lang === 'ua' ? 'uk' : lang}>{lang.toUpperCase()}</a>)}</div>
    </details>
    <button id="menuBtn" class="site-header__burger" aria-controls="mobileDrawer" aria-expanded="false" aria-label={t.menu}><span></span><span></span><span></span></button>
  </div>
</header>
<style>
  .site-header{position:sticky;z-index:10020;top:0;display:grid;grid-template-columns:auto 1fr auto;align-items:center;min-height:68px;padding:0 max(16px,5vw);background:rgba(255,255,255,.97);border-bottom:1px solid rgba(7,55,70,.12);box-shadow:0 7px 18px rgba(7,55,70,.12);font-family:Arial,Helvetica,sans-serif}.site-header__brand img{display:block;width:190px;height:auto}.site-header__nav{display:flex;align-items:center;justify-content:center;gap:clamp(16px,2vw,30px);white-space:nowrap}.site-header__nav a,.site-header__nav summary{position:relative;padding:25px 0;color:#073746;font-size:14px;font-weight:700;text-decoration:none;cursor:pointer;list-style:none}.site-header__nav summary::-webkit-details-marker,.site-header__languages summary::-webkit-details-marker{display:none}.site-header__languages summary::marker{content:''}.site-header__nav summary::after{content:'+';margin-left:6px;color:#d97706}.site-header__nav details[open] summary::after{content:'−'}.site-header__nav>a::after,.site-header__nav>details>summary::before{content:'';position:absolute;right:0;bottom:16px;left:0;height:2px;background:#d97706;transform:scaleX(0);transition:transform .18s ease}.site-header__nav>a:hover::after,.site-header__nav>details:hover>summary::before{transform:scaleX(1)}.site-header__nav details,.site-header__languages{position:relative}.site-header__submenu,.site-header__languages>div{position:absolute;z-index:10030;top:calc(100% - 8px);left:-18px;display:flex;min-width:210px;flex-direction:column;padding:8px;background:#fff;border:1px solid rgba(7,55,70,.14);box-shadow:0 14px 30px rgba(7,55,70,.16)}.site-header__submenu a{padding:12px 14px}.site-header__submenu a:hover,.site-header__languages a:hover{background:#edf5f4}.site-header__actions{display:flex;align-items:center;gap:10px}.site-header__languages summary{display:flex;align-items:center;min-height:28px;padding:0 10px;border-radius:8px;background:#ffb14b;color:#073746;font-size:14px;font-weight:700;cursor:pointer;list-style:none}.site-header__languages>div{right:0;left:auto;min-width:76px;padding:4px}.site-header__languages a{display:block;padding:10px;color:#073746;text-decoration:none}.site-header__burger{display:none;width:44px;height:44px;align-items:center;justify-content:center;flex-direction:column;gap:5px;background:#fff;border:1px solid rgba(7,55,70,.2);border-radius:6px}.site-header__burger span{display:block;width:22px;height:2px;background:#073746}@media(max-width:1100px){.site-header__nav{display:none}.site-header__burger{display:flex}}@media(max-width:600px){.site-header{padding:0 12px}.site-header__brand img{width:156px}}
</style>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.getElementById('menuBtn');
    const drawer = document.getElementById('mobileDrawer');
    const backdrop = document.getElementById('mobileBackdrop');
    button?.addEventListener('click', () => {
      const open = button.getAttribute('aria-expanded') !== 'true';
      button.setAttribute('aria-expanded', String(open));
      drawer?.classList.toggle('translate-x-full', !open);
      drawer?.classList.toggle('invisible', !open);
      backdrop?.classList.toggle('hidden', !open);
      backdrop?.classList.toggle('opacity-0', !open);
      backdrop?.classList.toggle('pointer-events-none', !open);
    });
  });
</script>
