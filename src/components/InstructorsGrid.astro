---
/**
 * Reusable instructor cards fed by Payload authors (kind 'author').
 * Matches the original charter/school "Инструкторская команда" white card:
 * round avatar, orange name, position, summary and training chips.
 * Props:
 *   locale         — 'ru' | 'ua' | 'en'
 *   trainingsLabel — heading of the chips row (optional)
 *   trainings      — string[] chips shown for every instructor (optional)
 */
import payloadContent from '~/data/payload-content.json';

interface Props { locale: string; trainingsLabel?: string; trainings?: string[] }
const { locale, trainingsLabel, trainings = [] } = Astro.props;
const dataLocale = locale === 'ua' ? 'uk' : locale;
const instructors = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'author' && e.locale === dataLocale)
  .sort((a: any, b: any) => (a.order ?? 99) - (b.order ?? 99));
---
<div class="navi-instructors">
  {instructors.map((person: any) => (
    <article class="navi-instructor-card">
      <a class="navi-instructor-card__head" href={person.route}>
        <img src={person.image?.sizes?.card?.url || person.image?.url} alt={person.image?.alt || person.name} width="100" height="100" loading="lazy" />
        <div>
          <h3>{person.name}</h3>
          {person.position && <p class="navi-instructor-card__role">{person.position}</p>}
        </div>
      </a>
      {person.summary && <p class="navi-instructor-card__summary">{person.summary}</p>}
      {trainings.length > 0 && (
        <div class="navi-instructor-card__trainings">
          {trainingsLabel && <p>{trainingsLabel}</p>}
          <div class="navi-instructor-card__chips">{trainings.map((chip) => <span>{chip}</span>)}</div>
        </div>
      )}
    </article>
  ))}
</div>
<style is:global>
  .navi-instructors{display:flex;flex-wrap:wrap;justify-content:center;gap:32px}
  .navi-instructor-card{box-sizing:border-box;width:min(100%,520px);padding:40px;border-radius:24px;background:#fff;color:var(--ds-ink,#073746);box-shadow:0 18px 48px rgba(3,29,38,.18)}
  .navi-instructor-card__head{display:flex;align-items:flex-start;gap:28px;color:inherit;text-decoration:none}
  .navi-instructor-card__head img{flex:none;width:100px;height:100px;border-radius:50%;object-fit:cover}
  .navi-instructor-card__head h3{margin:6px 0 6px;color:#f5a54a;font:700 24px/1.2 var(--font-neo,Arial,sans-serif)}
  .navi-instructor-card__role{margin:0;color:#45626c;font-size:16px}
  .navi-instructor-card__summary{margin:18px 0 0;font-size:16px;line-height:1.6}
  .navi-instructor-card__trainings{margin-top:22px}
  .navi-instructor-card__trainings>p{margin:0 0 12px;font-size:14px;font-weight:600}
  .navi-instructor-card__chips{display:flex;flex-wrap:wrap;gap:10px}
  .navi-instructor-card__chips span{padding:9px 14px;border-radius:8px;background:#f7ac57;color:#fff;font:500 13px/1 var(--font-neo,Arial,sans-serif)}
  @media (max-width:640px){
    .navi-instructor-card{padding:28px 22px}
    .navi-instructor-card__head{gap:18px}
    .navi-instructor-card__head img{width:80px;height:80px}
    .navi-instructor-card__head h3{font-size:20px;margin-top:0}
  }
</style>
