---
interface Props {
  images?: Array<{ src: string; alt?: string; href?: string }>
}
const { images } = Astro.props as Props;
const defaults = Array.from({ length: 12 }, (_, i) => ({ src: `/photos/${i + 1}.avif`, alt: '' }));
const base = images && images.length > 0 ? images : defaults;
const photos = [...base, ...base, ...base].slice(0, Math.min(base.length * 3, 36));
---
<section aria-label="Фото" class="astro-photo-strip">
  <div class="astro-photo-strip__grid">
    {photos.map((img) => (
      <img src={img.src} alt={img.alt ?? ''} loading="lazy" class="astro-photo-strip__image" />
    ))}
  </div>
</section>
<style is:global>
  .astro-photo-strip{width:100%;margin:0;padding:0;background:#073746;overflow:hidden}
  .astro-photo-strip__grid{display:flex;gap:4px;width:100%;overflow:hidden}
  .astro-photo-strip__image{display:block;flex:1 0 72px;height:auto;aspect-ratio:1/1;min-width:72px;object-fit:cover;margin:0}
  @media(min-width:768px){.astro-photo-strip__image{flex:1 0 96px;min-width:96px}}
  @media(min-width:1280px){.astro-photo-strip__image{flex:1 0 116px;min-width:116px}}
</style>
