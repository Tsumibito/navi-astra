---
interface Props {
  images?: Array<{ src: string; alt?: string; href?: string }>
}
const { images } = Astro.props as Props;
---
<section aria-label="Фото" class="astro-photo-strip">
  <!-- Full-bleed wrapper: stretch to viewport width -->
  <div class="relative z-0 left-1/2 ml-[-50vw] mr-[-50vw] w-screen overflow-hidden">
    <div class="astro-photo-strip__grid">
        {
          (() => {
            const defaults = Array.from({ length: 12 }, (_, i) => ({
              src: `/photos/${i + 1}.avif`,
              alt: '',
            }));
            const base = images && images.length > 0 ? images : defaults;
            // Повторяем до двух раз максимум
            return [...base, ...base].slice(0, Math.min(base.length * 2, 24));
          })().map((img) => (
            <img
              src={img.src}
              alt={img.alt ?? ''}
              loading="lazy"
              width="160"
              height="160"
              class="astro-photo-strip__image"
            />
          ))
        }
    </div>
  </div>
</section>
<style>
  .astro-photo-strip{width:100%;margin:0;padding:0;background:#073746;overflow:hidden}
  .astro-photo-strip__grid{display:flex;gap:4px;width:100%;overflow:hidden}
  .astro-photo-strip__image{display:block;flex:1 0 46px;min-width:46px;height:auto;aspect-ratio:1/1;object-fit:cover;margin:0}
</style>
