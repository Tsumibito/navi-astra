---
/**
 * FAQ accordion for blog/encyclopedia posts.
 * Renders when post has faqs[] in payload-content.
 * CSS: .navi-payload-faq (from navi-evolution-v1.css, loaded globally)
 */
import { renderLexical } from '../lib/render-lexical.mjs';

interface Props {
  faqs: any[];
  locale: string;
}

const { faqs, locale } = Astro.props;
const copy = {
  ru: { title: 'Частые вопросы', sub: 'Короткие ответы по теме' },
  ua: { title: 'Часті запитання', sub: 'Короткі відповіді за темою' },
  en: { title: 'FAQ', sub: 'Quick answers on the topic' },
}[locale as 'ru' | 'ua' | 'en'] ?? { title: 'FAQ', sub: 'Quick answers on the topic' };
---
{faqs.length > 0 && (
  <section class="navi-payload-faq" aria-labelledby="navi-faq-title">
    <header>
      <h2 id="navi-faq-title">{copy.title}</h2>
      <p>{copy.sub}</p>
    </header>
    <div class="navi-payload-faq__items">
      {faqs.map((faq: any) => (
        <details>
          <summary>{faq.question}<span aria-hidden="true">+</span></summary>
          <div class="navi-payload-faq__answer" set:html={renderLexical(faq.answer)} />
        </details>
      ))}
    </div>
  </section>
)}
