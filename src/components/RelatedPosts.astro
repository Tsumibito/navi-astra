---
/**
 * Reusable "Статьи о яхтинге от Navi.training" section.
 * Matches the homepage footer[data-evo-footer="0"] layout exactly.
 * Props:
 *   posts  — array of 3 post objects from payload-content.json
 *   locale — 'ru' | 'ua' | 'en'
 */
interface Props {
  posts: any[];
  locale: string;
}

const { posts, locale } = Astro.props;
const dataLocale = locale === 'ua' ? 'uk' : locale;
const copy = {
  ru: { title: 'Статьи о яхтинге от', sub: 'Новости, яхтенные лайфхаки и учебные материалы', more: 'Еще статьи', minRead: 'мин. чтения' },
  ua: { title: 'Статті про яхтинг від', sub: 'Новини, яхтові лайфхаки та навчальні матеріали', more: 'Ще статті', minRead: 'хв. читання' },
  en: { title: 'Yachting articles from', sub: 'News, sailing tips and training materials', more: 'More articles', minRead: 'min to read' },
}[locale as 'ru' | 'ua' | 'en'] ?? { title: 'Yachting articles from', sub: 'News, sailing tips and training materials', more: 'More articles', minRead: 'min to read' };

/* ponytail: naive word count from Lexical JSON — good enough for read-time estimate */
function extractText(node: any): string {
  if (!node) return '';
  if (typeof node === 'string') return node;
  let text = node.text ? node.text + ' ' : '';
  if (node.root) text += extractText(node.root);
  for (const child of node.children || []) text += extractText(child);
  return text;
}
function readTime(content: any): number {
  return Math.max(1, Math.round(extractText(content).split(/\s+/).length / 200));
}
---
{posts.length > 0 && (
  <section class="navi-rp">
    <div class="navi-rp__inner">
      <div class="navi-rp__head">
        <h2>{copy.title} <span class="navi-rp__brand">Navi.training</span></h2>
        <p>{copy.sub}</p>
      </div>
      <div class="navi-rp__grid">
        {posts.map((post: any) => {
          const img = post.image?.sizes?.card?.url || post.image?.url;
          const author = post.authors?.[0]?.value;
          const authorName = author && typeof author === 'object' ? author.name : null;
          const mins = readTime(post.content);
          return (
            <article>
              <a href={post.route}>
                <div class="navi-rp__img">
                  {img && <img src={img} alt={post.imageAlt || post.name} loading="lazy" width="300" height="160" />}
                </div>
              </a>
              <p>
                {authorName && <span>{authorName}</span>}
                <span class="navi-rp__time">
                  <img src="/cgi/asset/65f9715a5565847069a10a86_clock_wbbL_tR7VzDK4DZGIj3rp.svg" alt="" width="24" height="24" />
                  {mins} {copy.minRead}
                </span>
              </p>
              <h3><a href={post.route}>{post.name}</a></h3>
            </article>
          );
        })}
      </div>
      <div class="navi-rp__cta">
        <a href={`/${locale}/blog`}>{copy.more}</a>
      </div>
    </div>
  </section>
)}
<style is:global>
  /* Related-posts component — pixel-matches homepage footer[data-evo-footer="0"] */
  .navi-rp{width:100%;box-sizing:border-box;background:#fff;border-radius:var(--ds-radius-section-top,60px 60px 0 0);margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25))}
  .navi-rp__inner{width:min(1180px,calc(100% - 48px));margin-inline:auto;padding:64px 0 72px}
  .navi-rp__head{text-align:center;margin-bottom:32px}
  .navi-rp__head h2{margin:0 0 12px;font:400 clamp(32px,4.5vw,52px)/1.05 'Tenor Sans',sans-serif;letter-spacing:-1px;color:#000}
  .navi-rp__brand{color:#ffb052;font-style:italic}
  .navi-rp__head p{margin:0;color:#52656b;font-size:clamp(16px,1.4vw,19px);line-height:1.5}
  .navi-rp__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:clamp(18px,2.5vw,32px);margin-bottom:42px}
  .navi-rp__grid article{display:grid;grid-template-rows:auto auto 1fr;align-content:start;gap:4px}
  .navi-rp__grid article>*{margin-inline:0}
  .navi-rp__img{overflow:hidden;border-radius:18px;background:var(--ds-mist,#e9f2f1)}
  .navi-rp__img img{display:block;width:100%;aspect-ratio:16/9;object-fit:cover;transition:transform .35s ease}
  .navi-rp__grid article:hover .navi-rp__img img{transform:scale(1.03)}
  .navi-rp__grid article p{display:flex;align-items:center;justify-content:space-between;min-height:42px;margin:0;color:#52656b;font-size:13px;font-weight:500}
  .navi-rp__time{display:inline-flex;align-items:center;gap:6px}
  .navi-rp__time img{width:24px;height:24px;min-width:24px;object-fit:contain}
  .navi-rp__grid article h3{margin:8px 0 0;color:var(--ds-ink,#073746);font:400 18px/1.3 'Tenor Sans',sans-serif}
  .navi-rp__grid article h3 a{color:inherit;text-decoration:none}
  .navi-rp__grid article h3 a:hover{color:#ffb052}
  .navi-rp__cta{text-align:center;padding-top:10px}
  .navi-rp__cta a{display:inline-block;padding:15px 40px;color:#fff;background:#ffb052;border-radius:5px;font:700 15px/1.2 Arial,sans-serif;text-decoration:none;cursor:pointer;transition:background .2s}
  .navi-rp__cta a:hover{background:#e89a3a}
  @media(max-width:640px){.navi-rp{border-radius:36px 36px 0 0;margin-top:calc(-1 * var(--ds-section-overlap-mobile,36px))}.navi-rp__grid{grid-template-columns:1fr}.navi-rp__cta a{padding:12px 20px}}
</style>
