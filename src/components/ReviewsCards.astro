---
/**
 * Alumni video-review cards on the light-sea background, as on the original
 * sailing-school / course pages. Poster links open the Vimeo video.
 * Props: items — [{ quote, name, role, poster, avatar, vimeo }]
 */
interface Props { items: Array<{ quote: string; name: string; role: string; poster: string; avatar: string; vimeo?: string | null }> }
const { items } = Astro.props;
---
<div class="np-reviews">
  {items.map((review) => (
    <article class="np-review-card">
      {review.vimeo ? (
        <a class="np-review-card__video" href={`https://vimeo.com/${review.vimeo}`} target="_blank" rel="noopener">
          <img src={review.poster} alt={`${review.name} — video`} loading="lazy" width="360" height="220" />
          <span aria-hidden="true"></span>
        </a>
      ) : (
        <div class="np-review-card__video"><img src={review.poster} alt={review.name} loading="lazy" width="360" height="220" /></div>
      )}
      <p class="np-review-card__quote">{review.quote}</p>
      <footer>
        <img src={review.avatar} alt="" width="44" height="44" loading="lazy" />
        <div><b>{review.name}</b><span>{review.role}</span></div>
      </footer>
    </article>
  ))}
</div>
<style is:global>
  .np-reviews{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:36px;margin-top:70px;align-items:start}
  .np-review-card{box-sizing:border-box;padding:36px 32px;border-radius:20px;background:#fff;box-shadow:0 16px 40px rgba(7,55,70,.08)}
  .np-review-card:nth-child(2){margin-top:-36px}
  .np-review-card__video{position:relative;display:block;overflow:hidden;border-radius:12px}
  .np-review-card__video img{display:block;width:100%;aspect-ratio:360/220;object-fit:cover}
  .np-review-card__video span{position:absolute;inset:0;margin:auto;width:104px;height:56px;border-radius:16px;background:#f7ac57}
  .np-review-card__video span::after{content:'';position:absolute;inset:0;margin:auto;width:0;height:0;border-style:solid;border-width:11px 0 11px 19px;border-color:transparent transparent transparent #fff}
  .np-review-card__quote{margin:26px 0 24px;font-size:16px;line-height:1.62;color:#073746}
  .np-review-card footer{display:flex;align-items:center;gap:14px}
  .np-review-card footer img{width:44px;height:44px;border-radius:50%;object-fit:cover}
  .np-review-card footer b{display:block;color:#f5a54a;font-size:18px;font-weight:600}
  .np-review-card footer span{display:block;margin-top:4px;color:#073746;font-size:14px}
  @media (max-width:980px){
    .np-reviews{grid-template-columns:1fr;gap:24px;margin-top:40px}
    .np-review-card:nth-child(2){margin-top:0}
  }
</style>
