---
/**
 * Global lead-form modal using the native <dialog> element. Opened by any
 * element with [data-open-service-form], which gets commandfor/command="show-modal"
 * progressively in supported browsers. The click handler remains as a JS fallback.
 * Works on any layout because styles are embedded globally.
 */
const { service = 'general', locale = 'ru', title, intro, button } = Astro.props;
const t = locale === 'ua' ? { step:'Перший крок', name:'Як до вас звертатися', phone:'Телефон або месенджер', email:'E-mail', location:'Де знаходиться яхта', message:'Розкажіть про яхту та задачу', consent:'Я погоджуюся з', privacy:'політикою конфіденційності', close:'Закрити форму', sending:'Надсилаємо…', success:'Запит прийнято', successText:'Вивчу деталі та зв’яжуся з вами, щоб обговорити яхту й наступні кроки.', error:'Не вдалося надіслати. Напишіть на alex@navi.training або спробуйте ще раз.', title:'Залишити заявку', intro:'Час узяти курс на пригоди! Розкажіть, чим ми можемо допомогти, і ми звʼяжемося з вами найближчим часом.', button:'Відправити' } : locale === 'en' ? { step:'First step', name:'Your name', phone:'Phone or messenger', email:'Email', location:'Where is the yacht?', message:'Tell us about the yacht and your plans', consent:'I agree to the', privacy:'privacy policy', close:'Close form', sending:'Sending…', success:'Request received', successText:'I will review the details and contact you to discuss the yacht and next steps.', error:'Could not send. Email alex@navi.training or try again.', title:'Submit a request', intro:"It's time to set a course for adventure! Tell us how we can help and we will get back to you shortly.", button:'Submit' } : { step:'Первый шаг', name:'Как к вам обращаться', phone:'Телефон или мессенджер', email:'E-mail', location:'Где находится яхта', message:'Расскажите о яхте и задаче', consent:'Я согласен с', privacy:'политикой конфиденциальности', close:'Закрыть форму', sending:'Отправляем…', success:'Запрос принят', successText:'Изучу вводные и свяжусь с вами, чтобы обсудить яхту и следующие шаги.', error:'Не удалось отправить. Напишите на alex@navi.training или попробуйте ещё раз.', title:'Оставить заявку', intro:'Пора взять курс на приключения! Расскажите, чем мы можем помочь, и мы свяжемся с вами в ближайшее время.', button:'Отправить' };
const formTitle = title || t.title;
const formIntro = intro || t.intro;
const formButton = button || t.button;
const privacyHref = `/${locale}/privacy-policy`;
---
<dialog class="service-modal" data-service-modal id="service-modal" aria-modal="true" aria-labelledby="service-form-title">
  <section class="service-modal__card">
    <button class="service-modal__close" type="button" data-close-service-form aria-label={t.close}>×</button>
    <form class="service-form" data-service-lead data-service={service}>
      <div class="form-heading"><p class="eyebrow">{t.step}</p><h2 id="service-form-title">{formTitle}</h2><p>{formIntro}</p></div>
      <div class="form-grid">
        <label><span>{t.name}</span><input name="name" autocomplete="name" required /></label><label><span>{t.phone}</span><input name="phone" autocomplete="tel" required /></label>
        <label><span>{t.email}</span><input name="email" type="email" autocomplete="email" required /></label><label><span>{t.location}</span><input name="location" autocomplete="address-level2" /></label>
        <label class="form-wide"><span>{t.message}</span><textarea name="message" rows="4" required></textarea></label><input class="form-trap" name="company" tabindex="-1" autocomplete="off" />
        <label class="form-consent form-wide"><input name="consent" type="checkbox" required /><span>{t.consent} <a href={privacyHref}>{t.privacy}</a></span></label>
        <div class="form-action form-wide"><button type="submit">{formButton}<span aria-hidden="true">↗</span></button><p data-form-status aria-live="polite"></p></div>
      </div>
    </form>
  </section>
</dialog>
<style is:global>
  /* Lock body scroll when a dialog is open; keep the class for the newsletter overlay. */
  body:has(dialog[open]){overflow:hidden}
  .navi-modal-open{overflow:hidden}

  .service-modal { margin:auto; padding:20px; width:100%; max-width:100%; border:0; background:transparent; color:inherit; display:grid; place-items:center; opacity:0; transform:translateY(18px); transition:opacity .22s ease, transform .22s ease }
  .service-modal.is-open { opacity:1; transform:translateY(0) }
  .service-modal::backdrop { background:rgba(3,29,38,.76); backdrop-filter:blur(7px); opacity:0; transition:opacity .22s ease }
  .service-modal.is-open::backdrop { opacity:1 }

  .service-modal__card { position:relative; width:min(980px,calc(100vw - 32px)); max-height:calc(100vh - 40px); overflow:auto; padding:clamp(32px,5vw,66px); box-sizing:border-box; background:var(--ds-paper,#f7faf9); color:var(--ds-ink,#073746); box-shadow:0 28px 90px rgba(3,29,38,.28); border-radius:var(--ds-radius-feature,24px) }
  .service-modal__close { position:absolute; top:17px; right:20px; width:44px; height:44px; border:1px solid var(--ds-line,rgba(7,55,70,.16)); background:transparent; color:var(--ds-ink,#073746); font-size:30px; cursor:pointer; border-radius:9px }
  .service-modal .eyebrow { margin:0 0 20px; color:var(--ds-accent,#d97706); font:700 12px/1.4 Arial,sans-serif; letter-spacing:.18em; text-transform:uppercase }
  .service-modal .service-form { display:grid; grid-template-columns:.8fr 1.2fr; gap:60px }
  .service-modal .form-heading h2 { margin:0 0 25px; color:var(--ds-ink,#073746); font:400 clamp(38px,4vw,58px)/1.05 'Tenor Sans',serif }
  .service-modal .form-heading>p:last-child { margin:0; color:#476773; line-height:1.7 }
  .service-modal .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px }
  .service-modal .service-form label { display:flex; flex-direction:column; gap:9px }
  .service-modal .service-form label>span { font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:#365e69 }
  .service-modal .service-form input,.service-modal .service-form textarea { width:100%; box-sizing:border-box; border:0; border-bottom:1px solid rgba(7,55,70,.32); border-radius:0; background:transparent; padding:12px 2px; color:var(--ds-ink,#073746); font:16px var(--font-neo,Arial,sans-serif); outline:none }
  .service-modal .service-form input:focus,.service-modal .service-form textarea:focus { border-color:var(--ds-accent,#d97706) }
  .service-modal .form-wide { grid-column:1/-1 }
  .service-modal .form-trap { position:absolute; left:-9999px }
  .service-modal .form-consent { flex-direction:row !important; align-items:center }
  .service-modal .form-consent input { width:18px; height:18px; accent-color:var(--ds-accent,#d97706) }
  .service-modal .form-consent a { color:var(--ds-ink,#073746) }
  .service-modal .form-action { display:flex; align-items:center; gap:25px }
  .service-modal .form-action button { border:0; background:var(--ds-accent,#d97706); color:#fff; padding:18px 25px; font-weight:700; cursor:pointer; min-width:220px; border-radius:5px }
  .service-modal .form-action p { color:#476773; font-size:13px; margin:0 }
  .service-modal .form-success { grid-column:1/-1; padding:55px; border:1px solid var(--ds-line,rgba(7,55,70,.16)) }
  .service-modal .form-success span { color:var(--ds-accent,#d97706); font-size:40px }
  .service-modal .form-success h2 { font-size:48px; margin:20px 0 12px; font-family:'Tenor Sans',serif; font-weight:400 }
  .service-modal .form-success p { color:#476773 }

  @media (max-width:800px){
    .service-modal { padding:8px }
    .service-modal__card { width:calc(100vw - 16px); max-height:calc(100vh - 16px); padding:56px 24px 28px }
    .service-modal .service-form { grid-template-columns:1fr; gap:30px }
    .service-modal .form-grid { grid-template-columns:1fr }
    .service-modal .form-action { align-items:flex-start; flex-direction:column }
    .service-modal .service-form textarea { min-height:64px }
  }
</style>
<script define:vars={{ t, locale }}>
  const modal = document.querySelector('[data-service-modal]');
  if (modal && !modal.id) modal.id = 'service-modal';

  // Progressive enhancement: commandfor/command for browsers that support Invoker Commands.
  const openers = [...document.querySelectorAll('[data-open-service-form]')];
  openers.forEach((button) => {
    if (!button.getAttribute('commandfor')) {
      button.setAttribute('commandfor', modal.id);
      button.setAttribute('command', 'show-modal');
    }
  });

  const form = modal.querySelector('[data-service-lead]');
  const openModal = () => {
    if (!modal || modal.open) return;
    modal.showModal();
    requestAnimationFrame(() => modal.classList.add('is-open'));
    setTimeout(() => modal.querySelector('input')?.focus(), 250);
  };
  const closeModal = () => {
    if (!modal || !modal.open) return;
    modal.classList.remove('is-open');
    setTimeout(() => modal.close(), 220);
  };

  // Click handler is the JS fallback for browsers without command/commandfor.
  openers.forEach((button) => button.addEventListener('click', () => {
    if (button.dataset.service) form.dataset.service = button.dataset.service;
    openModal();
  }));
  modal.querySelectorAll('[data-close-service-form]').forEach((button) => button.addEventListener('click', (event) => { event.preventDefault(); closeModal(); }));
  modal.addEventListener('cancel', (event) => { event.preventDefault(); closeModal(); });
  modal.addEventListener('click', (event) => {
    const rect = modal.getBoundingClientRect();
    if (event.clientX < rect.left || event.clientX > rect.right || event.clientY < rect.top || event.clientY > rect.bottom) closeModal();
  });

  form.addEventListener('submit', async (event) => { event.preventDefault(); const button=form.querySelector('button[type="submit"]'); const status=form.querySelector('[data-form-status]'); const data=new FormData(form); button.disabled=true; status.textContent=t.sending; try { const response=await fetch('https://payload.navi.training/api/public/leads',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({kind:'contact',service:form.dataset.service,firstName:data.get('name'),email:data.get('email'),phone:data.get('phone'),message:`${data.get('message')}\n\nLocation: ${data.get('location')||'-'}`,company:data.get('company'),consent:true,locale,sourceUrl:location.href,utm:location.search.slice(1)})}); if(!response.ok) throw new Error(); form.innerHTML=`<div class="form-success"><span>✓</span><h2>${t.success}</h2><p>${t.successText}</p></div>`; } catch { status.textContent=t.error; button.disabled=false; } });
</script>
