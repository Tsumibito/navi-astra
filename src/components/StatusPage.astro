---
interface Props {
  locale: 'ru' | 'ua' | 'en';
  code: string;
  eyebrow: string;
  title: string;
  message: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}

const {
  locale,
  code,
  eyebrow,
  title,
  message,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<div class="status-shell">
  <header class="status-header">
    <a href={`/${locale}/home`} aria-label="Navi.training — home">
      <img src="/navi_training_logo_c1.avif" alt="Navi.training" width="210" height="48" />
    </a>
    <span>{code}</span>
  </header>

  <main class="status-main">
    <div class="chart" aria-hidden="true">
      <svg viewBox="0 0 720 360" role="presentation">
        <path class="grid" d="M0 72H720M0 144H720M0 216H720M0 288H720M144 0V360M288 0V360M432 0V360M576 0V360" />
        <path class="route" d="M22 295C128 286 146 220 231 229S344 291 423 215 510 64 690 78" />
        <circle cx="22" cy="295" r="7" />
        <circle class="destination" cx="690" cy="78" r="11" />
      </svg>
      <strong>{code}</strong>
    </div>

    <section class="status-copy" aria-labelledby="status-title">
      <p class="eyebrow">{eyebrow}</p>
      <h1 id="status-title">{title}</h1>
      <p class="message">{message}</p>
      <nav aria-label="Page actions">
        <a class="primary" href={primaryHref}>{primaryLabel}</a>
        <a class="secondary" href={secondaryHref}>{secondaryLabel}</a>
      </nav>
    </section>
  </main>

  <footer>
    <span>43°09′ N · 5°36′ E</span>
    <span>Navi.training</span>
  </footer>
</div>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { background: #f7faf9; }
  :global(body) { margin: 0; color: #073746; background: #f7faf9; font-family: Arial, Helvetica, sans-serif; }
  .status-shell { min-height: 100svh; display: grid; grid-template-rows: auto 1fr auto; overflow: hidden; }
  .status-header, footer { width: min(1180px, calc(100% - 48px)); margin-inline: auto; display: flex; align-items: center; justify-content: space-between; }
  .status-header { min-height: 92px; border-bottom: 1px solid rgba(7,55,70,.16); }
  .status-header img { display: block; width: 190px; height: auto; }
  .status-header span, footer { color: #506970; font-size: 12px; letter-spacing: .16em; text-transform: uppercase; }
  .status-main { width: min(1180px, calc(100% - 48px)); margin: auto; display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(320px, .92fr); align-items: center; gap: clamp(40px, 7vw, 100px); padding-block: 64px; }
  .chart { min-height: 420px; position: relative; display: grid; place-items: center; border: 1px solid rgba(7,55,70,.14); background: #edf5f3; overflow: hidden; }
  .chart::before { content: ''; position: absolute; width: 62%; aspect-ratio: 1; border: 1px solid rgba(7,55,70,.18); border-radius: 50%; }
  .chart svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .grid { fill: none; stroke: rgba(7,55,70,.075); stroke-width: 1; }
  .route { fill: none; stroke: #ce650e; stroke-width: 3; stroke-linecap: round; stroke-dasharray: 8 12; }
  .chart circle { fill: #073746; }
  .chart .destination { fill: #ce650e; stroke: #fff; stroke-width: 5; }
  .chart strong { position: relative; font-family: Georgia, 'Times New Roman', serif; font-size: clamp(104px, 16vw, 210px); font-weight: 400; letter-spacing: -.08em; color: #073746; line-height: 1; }
  .eyebrow { margin: 0 0 18px; color: #9b4600; font-size: 12px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; }
  h1 { margin: 0; max-width: 680px; font-family: Georgia, 'Times New Roman', serif; font-size: clamp(42px, 5vw, 72px); font-weight: 400; line-height: .98; letter-spacing: -.035em; }
  .message { max-width: 590px; margin: 28px 0 36px; color: #405b63; font-size: 18px; line-height: 1.65; }
  nav { display: flex; align-items: center; flex-wrap: wrap; gap: 18px; }
  nav a { min-height: 48px; display: inline-flex; align-items: center; justify-content: center; padding: 0 24px; border: 1px solid #073746; color: #073746; font-weight: 700; text-decoration: none; transition: transform .2s ease, background .2s ease, color .2s ease; }
  nav a:hover { transform: translateY(-2px); }
  nav a:focus-visible { outline: 3px solid #ce650e; outline-offset: 4px; }
  nav .primary { background: #073746; color: #fff; }
  nav .secondary:hover { background: #fff; }
  footer { min-height: 72px; border-top: 1px solid rgba(7,55,70,.16); }
  @media (max-width: 760px) {
    .status-header, footer, .status-main { width: min(100% - 32px, 560px); }
    .status-header { min-height: 76px; }
    .status-header img { width: 160px; }
    .status-main { grid-template-columns: 1fr; gap: 32px; padding-block: 36px 48px; }
    .chart { min-height: 250px; }
    .chart strong { font-size: 112px; }
    .message { margin-block: 22px 28px; font-size: 16px; }
    nav { align-items: stretch; flex-direction: column; }
    nav a { width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) { nav a { transition: none; } }
</style>
