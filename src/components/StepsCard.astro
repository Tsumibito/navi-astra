---
/**
 * Dark rounded card with four numbered steps and decorative curved arrows,
 * as on the original charter and inshore-skipper pages.
 * Props: items — four step texts in order 1..4.
 */
interface Props { items: string[] }
const { items } = Astro.props;
---
<div class="np-steps__card">
  {items.map((text, index) => (
    <div class="np-steps__item"><i>{index + 1}</i><p>{text}</p></div>
  ))}
  <img class="np-steps__arrow np-steps__arrow--a" src="/cgi/asset/65feaab40e8860067f36ef59_strelka_aN5pQAzK4n5q5HuEKMSLi.svg" alt="" aria-hidden="true" loading="lazy" />
  <img class="np-steps__arrow np-steps__arrow--b" src="/cgi/asset/65feac6f52ec61fb42764646_strelka_up_YXIEFqtDrZlBelyz_fNYf.svg" alt="" aria-hidden="true" loading="lazy" />
  <img class="np-steps__arrow np-steps__arrow--c" src="/cgi/asset/65feaab40e8860067f36ef59_strelka_aN5pQAzK4n5q5HuEKMSLi.svg" alt="" aria-hidden="true" loading="lazy" />
</div>
<style is:global>
  .np-steps__card{position:relative;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:90px 30px;margin-top:60px;padding:70px 50px;border-radius:24px;background:#0a3849}
  .np-steps__item:nth-child(1){grid-area:1/1}
  .np-steps__item:nth-child(2){grid-area:2/2}
  .np-steps__item:nth-child(3){grid-area:1/3}
  .np-steps__item:nth-child(4){grid-area:2/4}
  .np-steps__item{text-align:center}
  .np-steps__item i{display:grid;place-items:center;width:68px;height:68px;margin:0 auto 24px;border-radius:50%;background:#2196d8;color:#fff;font:400 26px/1 var(--font-neo,Arial,sans-serif);font-style:normal}
  .np-steps__item:nth-child(1) i{background:#ffb052}
  .np-steps__item p{max-width:250px;margin:0 auto;font-size:16px;line-height:1.6;color:#fff}
  .np-steps__arrow{position:absolute;width:150px;height:auto;pointer-events:none}
  .np-steps__arrow--a{top:12%;left:20%}
  .np-steps__arrow--b{top:44%;left:45.5%}
  .np-steps__arrow--c{top:12%;left:70%}
  @media (max-width:980px){
    .np-steps__card{grid-template-columns:1fr 1fr;gap:56px 24px;padding:50px 30px}
    .np-steps__item:nth-child(n){grid-area:auto}
    .np-steps__arrow{display:none}
  }
  @media (max-width:640px){
    .np-steps__card{grid-template-columns:1fr;gap:40px}
  }
</style>
