---
interface Props {
  variant?: 'media' | 'article' | 'logbook' | 'stat' | 'logo';
  href?: string;
  image?: string;
  imageAlt?: string;
  title?: string;
  class?: string;
}
const { variant = 'media', href, image, imageAlt = '', title, class: className } = Astro.props as Props;
const Tag = href ? 'a' : 'article';
---
<Tag class:list={['ds-card', `ds-card--${variant}`, className]} href={href}>
  {image && <img class="ds-card__image" src={image} alt={imageAlt} loading="lazy" />}
  <div class="ds-card__body">
    {title && <h3>{title}</h3>}
    <slot />
  </div>
</Tag>

