---
interface Stat { value: string; label: string }
interface Props { title?: string; description?: string; stats: Stat[] }
const { title, description, stats } = Astro.props as Props;
---
<section class="ds-stat-panel">
  {(title || description) && <header><h2>{title}</h2>{description && <p>{description}</p>}<slot name="action" /></header>}
  <div class="ds-stat-panel__grid">
    {stats.map((stat) => <div class="ds-card ds-card--stat"><strong>{stat.value}</strong><span>{stat.label}</span></div>)}
  </div>
</section>

