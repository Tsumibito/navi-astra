---
/**
 * Shared charter page for ru/ua/en /charter.
 * Composition and measurements replicate the production original; rental
 * cards use the canonical navi-card-grid / navi-card--media classes from
 * navi-evolution-v1.css. Shared blocks live in stacked-pages.css.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import InstructorsGrid from '~/components/InstructorsGrid.astro';
import StepsCard from '~/components/StepsCard.astro';
import charterContent from '~/data/pages/charter.json';
import { accentHtml } from '~/lib/accent-html.mjs';
import '~/styles/stacked-pages.css';

interface Props { locale?: 'ru' | 'ua' | 'en' }
const { locale = 'ru' } = Astro.props;
const c = (charterContent as any)[locale];
const routes = { ru: '/ru/charter', en: '/en/charter', ua: '/ua/charter' };

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: c.hero.title.replace('\n', ' '),
    description: c.meta.description,
    provider: { '@type': 'Organization', name: 'Navi.training', url: 'https://navi.training' },
    serviceType: 'Yacht charter with skipper',
    availableLanguage: ['ru', 'uk', 'en'],
    url: `https://navi.training${routes[locale]}/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faq.items.map((item: any) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
];
---
<BaseLayout locale={locale} title={c.meta.title} description={c.meta.description} languageHrefs={routes} structuredData={structuredData} fullBleed={true} leadForm={{ service: 'charter' }}>
  <section class="np-hero np-hero--center ch-hero">
    <div class="np-shell">
      <p class="np-hero__eyebrow">{c.hero.eyebrow}</p>
      <h1 set:html={accentHtml(c.hero.title)} />
      <p class="np-hero__lead" set:html={accentHtml(c.hero.lead)} />
      <button class="np-btn" data-open-service-form type="button">{c.hero.cta}</button>
    </div>
  </section>

  <section class="np-sec ch-rent">
    <div class="np-shell">
      <h2 class="np-center-h2" set:html={accentHtml(c.rent.heading)} />
      <div class="navi-card-grid ch-rent__grid">
        {c.rent.cards.map((card: any) => (
          <button class="navi-card navi-card--media ch-rent__card" type="button" data-open-service-form>
            <div><img src={card.img} alt={card.title} loading="lazy" width="375" height="500" /></div>
            <h3>{card.title}</h3>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="np-sec np-stats">
    <div class="np-shell">
      <div class="np-cols">
        <h2 class="np-h2">{c.stats.heading}</h2>
        <div>
          <div class="np-body" set:html={accentHtml(c.stats.body)} />
          <button class="np-btn" data-open-service-form type="button">{c.stats.cta}</button>
        </div>
      </div>
      <div class="np-stats__row">
        {c.stats.cells.map((cell: any) => (
          <div class="np-stats__cell"><strong set:html={accentHtml(cell.value)} /><p>{cell.label}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="np-sec ch-value">
    <div class="np-shell">
      <div class="np-cols ch-cols--value">
        <h2 set:html={accentHtml(c.value.heading)} />
        <div class="np-body ch-body--ink" set:html={accentHtml(c.value.body)} />
      </div>
      <div class="ch-dest">
        {c.destinations.map((dest: any) => (
          <figure class="ch-dest__card">
            <img src={dest.img} alt={dest.name} loading="lazy" width="328" height="213" />
            <figcaption><span>{dest.region}</span><b>{dest.name}</b></figcaption>
          </figure>
        ))}
      </div>
      <div class="np-center-action"><button class="np-btn" data-open-service-form type="button">{c.value.cta}</button></div>
    </div>
  </section>

  <section class="np-sec ch-steps">
    <div class="np-shell">
      <div class="np-cols">
        <h2 class="np-h2">{c.steps.heading}</h2>
        <div>
          <div class="np-body" set:html={accentHtml(c.steps.body)} />
          <button class="np-btn" data-open-service-form type="button">{c.steps.cta}</button>
        </div>
      </div>
      <StepsCard items={c.steps.items} />
    </div>
  </section>

  <section class="np-sec np-brands">
    <div class="np-shell">
      <h2 class="np-center-h2 np-center-h2--small" set:html={accentHtml(c.brands.heading)} />
      <div class="np-brands__row">
        {c.brands.logos.map((logo: string) => <img src={logo} alt="" loading="lazy" width="200" height="78" />)}
      </div>
    </div>
  </section>

  <section class="np-sec np-team">
    <div class="np-shell">
      <h2 class="np-team__title">{c.team.heading}</h2>
      <p class="np-team__subtitle">{c.team.subtitle}</p>
      <InstructorsGrid locale={locale} trainingsLabel={c.team.trainingsLabel} trainings={c.team.trainings} />
      <div class="np-team__join">
        <h3>{c.team.joinTitle}</h3>
        <p>{c.team.joinBody}</p>
        <a class="np-btn" href={c.team.joinHref}>{c.team.joinCta}</a>
      </div>
    </div>
  </section>

  <section class="np-sec np-faq">
    <div class="np-shell">
      <div class="np-faq__head">
        <h2>{c.faq.title}</h2>
        <p>{c.faq.subtitle}</p>
      </div>
      <FaqAccordion items={c.faq.items} />
      <div class="np-faq__cta">
        <h3>{c.faq.ctaTitle}</h3>
        <p>{c.faq.ctaBody}</p>
        <button class="np-btn" data-open-service-form type="button">{c.faq.ctaButton}</button>
      </div>
    </div>
  </section>

  <section class="np-sec np-photo-cta">
    <div class="np-shell">
      <div class="np-cols np-cols--center">
        <h2 class="np-h2">{c.final.heading}</h2>
        <div>
          <div class="np-body" set:html={accentHtml(c.final.body)} />
          <button class="np-btn" data-open-service-form type="button">{c.final.cta}</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .ch-hero{background-image:linear-gradient(rgba(0,0,0,.49),rgba(0,0,0,.49)),url('/cgi/asset/661bca29e82e221ac7a814de_Charter_jn4pnAshLrmHM-gTKb1X6.jpg')}
  .ch-hero h1{max-width:12ch}
  .ch-rent{background:#e9f2f1}
  .ch-rent .np-center-h2{margin-bottom:80px}
  .ch-rent__card{padding:0;border:0;cursor:pointer;text-align:left;font:inherit}
  .ch-rent__card h3{font:700 20px/1.3 var(--font-neo,Arial,sans-serif)}
  .ch-cols--value{grid-template-columns:.65fr 1fr}
  .ch-value{background:#fff;color:#073746}
  .ch-value h2{margin:20px 0 40px;font:400 62px/1.06 'Tenor Sans',sans-serif;letter-spacing:-1.55px;color:#000}
  .ch-body--ink{color:#073746;margin-bottom:0}
  .ch-body--ink .accent{color:#f0a147}
  .ch-dest{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:44px 30px;margin-top:90px;padding:0 60px}
  .ch-dest__card{margin:0}
  .ch-dest__card img{display:block;width:100%;aspect-ratio:328/213;object-fit:cover;border-radius:12px 12px 0 0}
  .ch-dest__card figcaption{padding-top:16px}
  .ch-dest__card figcaption span{display:block;margin-bottom:6px;color:#3d7f9e;font-size:18px}
  .ch-dest__card figcaption b{color:#073746;font-size:22px;font-weight:700}
  .ch-steps{background:linear-gradient(#3ca8e2,#05283b);color:#fff}
  .ch-steps .np-h2{color:#fff}
  .ch-steps .np-body{color:#fff}
  @media (max-width:980px){
    .ch-cols--value{grid-template-columns:1fr}
    .ch-dest{grid-template-columns:repeat(2,minmax(0,1fr));padding:0;margin-top:60px}
  }
  @media (max-width:640px){
    .ch-rent .np-center-h2{margin-bottom:40px}
    .ch-value h2{font-size:30px;letter-spacing:-.75px}
    .ch-dest{grid-template-columns:repeat(2,minmax(0,1fr));gap:24px 16px;margin-top:40px}
    .ch-dest__card img{display:none}
    .ch-dest__card figcaption{padding-top:0}
    .ch-dest__card figcaption span{font-size:13px;margin-bottom:3px}
    .ch-dest__card figcaption b{font-size:15px}
  }
</style>
