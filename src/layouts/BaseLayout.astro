---
import "../styles/global.css";
import "@phosphor-icons/web/regular";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PhotoStrip from "../components/PhotoStrip.astro";
import NavMenu from "../components/NavMenu.astro";
const {
  title = 'Navi Astro', description = 'Astro 5 + Tailwind starter', locale = 'ru',
  canonical: canonicalOverride, image, structuredData, languageHrefs = {},
} = Astro.props;
const canonicalPath = Astro.url.pathname === '/' ? '/' : `${Astro.url.pathname.replace(/\/+$/, '')}/`;
const canonical = canonicalOverride || `https://navi.training${canonicalPath}`;
const navByLocale: Record<string, Array<{ label: string; href: string }>> = {
  ru: [
    { label: 'Путешествия', href: '/ru/tags/sailing-routes' },
    { label: 'Аренда яхт', href: '/ru/charter' },
    { label: 'Блог', href: '/ru/blog' },
    { label: 'Энциклопедия', href: '/ru/encyclopedia' },
  ],
  ua: [
    { label: 'Головна', href: '/ua/' },
    { label: 'Подорожі', href: '/ua/tags/sailing-routes' },
    { label: 'Оренда яхт', href: '/ua/charter' },
    { label: 'Блог', href: '/ua/blog' },
    { label: 'Енциклопедія', href: '/ua/encyclopedia' },
  ],
  en: [
    { label: 'Home', href: '/en/' },
    { label: 'Yacht travel', href: '/en/tags/sailing-routes' },
    { label: 'Yacht charter', href: '/en/charter' },
    { label: 'Journal', href: '/en/blog' },
    { label: 'Encyclopedia', href: '/en/encyclopedia' },
  ],
  fr: [
    { label: 'Accueil', href: '/fr/' },
    { label: 'École', href: '/fr/school' },
    { label: 'Charter', href: '/fr/charter' },
    { label: 'Convoyage', href: '/fr/delivery' },
    { label: 'Articles', href: '/fr/blog' },
    { label: 'Contacts', href: '/fr/contacts' },
  ],
};
const items = navByLocale[locale] ?? navByLocale['en'];
const langs = ['ru','ua','en'] as const;
---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {Object.entries(languageHrefs).map(([lang, href]) => <link rel="alternate" hreflang={lang === 'ua' ? 'uk' : lang} href={`https://navi.training${href}`} />)}
    {languageHrefs.ru && <link rel="alternate" hreflang="x-default" href={`https://navi.training${languageHrefs.ru}`} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData).replaceAll('<', '\\u003c')} />}
    <link rel="icon" href="/cgi/asset/Navi_logo_48x48_Jrw0nV6TLB6EdlDeYrhlw.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/cgi/asset/Navi_logo_150x150_C_9IEN2-7O865fBBu5MBc.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="stylesheet" href="/navi-runtime.css" />
    <link rel="stylesheet" href="/navi-evolution-v1.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tenor+Sans&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-white text-black antialiased font-neo flex flex-col">
    <Header locale={locale} languageHrefs={languageHrefs} />
    <!-- Мобильный выезжающий сайдбар вынесен на уровень layout -->
    <div id="mobileBackdrop" class="fixed left-0 right-0 bottom-0 z-30 hidden opacity-0 bg-black/60 transition-opacity pointer-events-none md:hidden" style="top:0;"></div>
    <div id="mobileDrawer" class="fixed right-0 bottom-0 z-40 w-[80vw] sm:w-[70vw] translate-x-full bg-white shadow-2xl md:hidden transition-transform duration-300 ease-out transform-gpu will-change-transform invisible" style="top:0;">
      <div class="px-[30px] pb-[30px] pt-[26px] space-y-6">
        <div class="mt-[10px]">
          <NavMenu items={items} class="flex-col items-center gap-y-3 text-lg" />
        </div>
        <div class="h-px w-full bg-slate-200" />
        <div class="flex items-center justify-center gap-3 text-sm">
          {langs.map((l) => (
            <a href={l == 'ru' ? '/' : `/${l}/`} class={`uppercase tracking-wide hover:text-brand-orangeDark transition-colors ${l === locale ? 'text-black font-medium' : 'text-slate-600'}`}>{l}</a>
          ))}
        </div>
        <a href={locale === 'ru' ? '/ru/apply' : locale === 'ua' ? '/ua/apply' : locale === 'fr' ? '/fr/apply' : '/en/apply'} class="inline-flex w-full items-center justify-center rounded-md bg-brand-orange px-4 py-[18px] text-sm font-medium text-black hover:bg-brand-orangeDark hover:text-white transition-colors">{locale === 'ru' ? 'Подать заявку' : locale === 'ua' ? 'Подати заявку' : locale === 'fr' ? 'Soumettre' : 'Apply'}</a>
      </div>
    </div>
    <main class="container mx-auto px-6 py-10 flex-1">
      <slot />
    </main>
    <PhotoStrip />
    <Footer locale={locale} />
    <script src="/navi-runtime.js" defer></script>
  </body>
</html>
