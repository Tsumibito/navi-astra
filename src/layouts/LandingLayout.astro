---
import CourseUnavailableModal from '../components/CourseUnavailableModal.astro';
import Footer from '../components/Footer.astro';
import PhotoStrip from '../components/PhotoStrip.astro';
interface Alternate { hreflang: string; href: string }
interface Props {
  locale: 'ru' | 'ua' | 'en';
  title: string;
  description: string;
  canonical: string;
  alternates?: Alternate[];
  og?: { url?: string; title?: string; description?: string; image?: string; type?: string; site_name?: string };
  schema?: object;
  styleTags?: string[];
}
const { locale, title, description, canonical, alternates = [], og = {}, schema, styleTags = [] } = Astro.props;
const langTag = locale === 'ua' ? 'uk-UA' : locale === 'en' ? 'en' : 'ru-RU';
---
<!DOCTYPE html>
<html lang={langTag}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <meta property="og:url" content={og.url ?? canonical} />
    {og.title && <meta property="og:title" content={og.title} />}
    {og.description && <meta property="og:description" content={og.description} />}
    {og.image && <meta property="og:image" content={og.image} />}
    {og.type && <meta property="og:type" content={og.type} />}
    {og.site_name && <meta property="og:site_name" content={og.site_name} />}
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />}
    <link rel="icon" href="/cgi/asset/Navi_logo_48x48_Jrw0nV6TLB6EdlDeYrhlw.png" type="image/png" />
    {styleTags.map((tag) => <Fragment set:html={tag} />)}
    <link rel="stylesheet" href="/navi-runtime.css" />
    <style is:global>
      .w-accordion { display: flex; flex-direction: column; }
      .w-accordion details.w-item { border-top: 1px solid rgba(7,55,70,.12); }
      .w-accordion details.w-item > summary { list-style: none; cursor: pointer; }
      .w-accordion details.w-item > summary::-webkit-details-marker { display: none; }
    </style>
  </head>
  <body class="w-body" data-navi-evolution="v6" data-navi-page="generic">
    <slot />
    <PhotoStrip />
    <Footer locale={locale} />
    <CourseUnavailableModal locale={locale} />
    <script is:inline defer>
      (() => {
        // Prevent navi-runtime.js from handling these buttons and open the temporary form instead.
        document.querySelectorAll('[data-navi-formbutton]').forEach((button) => {
          button.removeAttribute('data-navi-formbutton');
          button.setAttribute('data-course-unavailable', '');
          if (button.getAttribute('href') === '#') button.removeAttribute('href');
        });
        const modal = document.getElementById('course-unavailable-modal');
        if (!modal) return;
        const openModal = () => {
          if (modal.open) return;
          modal.showModal();
          requestAnimationFrame(() => modal.classList.add('is-open'));
          setTimeout(() => modal.querySelector('input[type="email"]')?.focus(), 250);
        };
        document.querySelectorAll('[data-course-unavailable]').forEach((button) => {
          button.addEventListener('click', (event) => {
            event.preventDefault();
            openModal();
          });
        });
      })();
    </script>
    <script src="/navi-runtime.js" defer></script>
  </body>
</html>
