---
interface Alternate { hreflang: string; href: string }
interface Props {
  locale: 'ru' | 'ua' | 'en';
  title: string;
  description: string;
  canonical: string;
  alternates?: Alternate[];
  og?: { url?: string; title?: string; description?: string; image?: string; type?: string; site_name?: string };
  schema?: object;
  styleTags?: string[];
}
const { locale, title, description, canonical, alternates = [], og = {}, schema, styleTags = [] } = Astro.props;
const langTag = locale === 'ua' ? 'uk-UA' : locale === 'en' ? 'en' : 'ru-RU';
---
<!DOCTYPE html>
<html lang={langTag}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <meta property="og:url" content={og.url ?? canonical} />
    {og.title && <meta property="og:title" content={og.title} />}
    {og.description && <meta property="og:description" content={og.description} />}
    {og.image && <meta property="og:image" content={og.image} />}
    {og.type && <meta property="og:type" content={og.type} />}
    {og.site_name && <meta property="og:site_name" content={og.site_name} />}
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />}
    <link rel="icon" href="/cgi/asset/Navi_logo_48x48_Jrw0nV6TLB6EdlDeYrhlw.png" type="image/png" />
    {styleTags.map((tag) => <Fragment set:html={tag} />)}
    <link rel="stylesheet" href="/navi-runtime.css" />
    <style is:global>
      .w-item-content.landing-accordion-content { padding: 0 24px 24px; color: inherit; }
      .w-item-content.landing-accordion-content p { margin: 0 0 .75em; white-space: normal; }
    </style>
  </head>
  <body class="w-body" data-navi-evolution="v6" data-navi-page="generic">
    <slot />
    <script is:inline defer>
      (() => {
        const ctx = window.__remixContext;
        if (!ctx) return;
        const route = Object.values(ctx.state.loaderData).find((v) => v?.resources && (v.resources.FAQ_1 || v.resources.FAQ));
        const faq = route?.resources?.FAQ_1?.data?.results || [];
        const accordions = [...document.querySelectorAll('.w-accordion')];
        accordions.forEach((acc, i) => {
          const item = acc.querySelector('.w-item');
          const trigger = item?.querySelector('.w-item-trigger');
          const data = faq[i];
          if (!item || !trigger) return;
          const panel = document.createElement('div');
          panel.className = 'w-item-content landing-accordion-content';
          panel.setAttribute('data-orientation', 'vertical');
          panel.setAttribute('data-state', 'closed');
          panel.hidden = true;
          panel.id = `landing-faq-panel-${i}`;
          if (data?.field_2660146) {
            const paragraphs = String(data.field_2660146).split(/\n\s*\n/).filter(Boolean).map((p) => {
              const el = document.createElement('p');
              el.textContent = p.trim();
              return el;
            });
            if (!paragraphs.length) {
              const el = document.createElement('p');
              el.textContent = String(data.field_2660146).trim();
              panel.append(el);
            } else {
              panel.append(...paragraphs);
            }
          }
          item.append(panel);
          trigger.setAttribute('aria-controls', panel.id);
          trigger.setAttribute('aria-expanded', 'false');
          trigger.addEventListener('click', () => {
            const opening = item.getAttribute('data-state') === 'closed';
            item.setAttribute('data-state', opening ? 'open' : 'closed');
            trigger.setAttribute('data-state', opening ? 'open' : 'closed');
            trigger.setAttribute('aria-expanded', String(opening));
            panel.setAttribute('data-state', opening ? 'open' : 'closed');
            panel.hidden = !opening;
          });
        });
      })();
    </script>
    <script src="/navi-runtime.js" defer></script>
  </body>
</html>
