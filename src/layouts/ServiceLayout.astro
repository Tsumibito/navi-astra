---
import "../styles/global.css";
import "../styles/services.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PhotoStrip from "../components/PhotoStrip.astro";

const { title, description, image, locale = 'ru', slug, schema } = Astro.props;
const languageHrefs = Object.fromEntries(['ru','ua','en'].map((lang) => [lang, `/${lang}/${slug}`]));
const canonical = `https://navi.training/${locale}/${slug}`;
---
<html lang={locale === 'ua' ? 'uk' : locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ru" href={`https://navi.training/ru/${slug}`} />
    <link rel="alternate" hreflang="uk" href={`https://navi.training/ua/${slug}`} />
    <link rel="alternate" hreflang="en" href={`https://navi.training/en/${slug}`} />
    <link rel="alternate" hreflang="x-default" href={`https://navi.training/ru/${slug}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'ua' ? 'uk_UA' : locale === 'en' ? 'en_US' : 'ru_RU'} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/cgi/asset/Navi_logo_48x48_Jrw0nV6TLB6EdlDeYrhlw.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/navi-evolution-v1.css" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Tenor+Sans&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="service-body" data-navi-evolution="v6">
    <Header locale={locale} languageHrefs={languageHrefs} />
    <div id="mobileBackdrop" class="fixed inset-x-0 bottom-0 top-[68px] z-[10000] hidden bg-black/60 opacity-0 pointer-events-none md:hidden"></div>
    <aside id="mobileDrawer" class="fixed right-0 bottom-0 top-[68px] z-[10010] w-[82vw] translate-x-full invisible bg-white p-6 shadow-2xl transition-transform md:hidden">
      <nav class="grid gap-2" aria-label="Mobile navigation">
        <a class="rounded-lg p-3" href={locale === 'ru' ? '/' : `/${locale}/home`}>{locale === 'ua' ? 'Головна' : locale === 'en' ? 'Home' : 'Главная'}</a>
        <a class="rounded-lg p-3" href={`/${locale}/charter`}>{locale === 'ua' ? 'Оренда яхт' : locale === 'en' ? 'Yacht charter' : 'Аренда яхт'}</a>
        <a class="rounded-lg p-3" href={`/${locale}/blog`}>{locale === 'en' ? 'Journal' : 'Блог'}</a>
        <a class="rounded-lg p-3" href={`/${locale}/encyclopedia`}>{locale === 'ua' ? 'Яхтова енциклопедія' : locale === 'en' ? 'Sailing encyclopedia' : 'Яхтенная энциклопедия'}</a>
        <button type="button" data-open-service-form class="mt-3 rounded-lg bg-brand-orange p-4 text-left font-bold">{locale === 'ua' ? 'Обговорити задачу' : locale === 'en' ? 'Discuss the project' : 'Обсудить задачу'}</button>
      </nav>
    </aside>
    <main><slot /></main>
    <PhotoStrip />
    <Footer locale={locale} />
    <script src="/navi-runtime.js" defer></script>
  </body>
</html>
