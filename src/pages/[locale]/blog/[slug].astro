---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import payloadContent from '../../../data/payload-content.json';
import { renderLexical } from '../../../lib/render-lexical.mjs';

export function getStaticPaths() {
  return (payloadContent.entries || [])
    .filter((entry: any) => entry.kind === 'post')
    .map((post: any) => {
      const locale = post.locale === 'uk' ? 'ua' : post.locale;
      const slug = post.route.split('/').filter(Boolean).at(-1);
      return { params: { locale, slug }, props: { post } };
    });
}

const { post } = Astro.props;
const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const copy = {
  ru: { back: 'Бортовой журнал', related: 'Статьи о яхтинге от', relatedSub: 'Новости, яхтенные лайфхаки и учебные материалы' },
  ua: { back: 'Бортовий журнал', related: 'Статті про яхтинг від', relatedSub: 'Новини, яхтові лайфхаки та навчальні матеріали' },
  en: { back: 'Journal', related: 'Yachting articles from', relatedSub: 'News, sailing tips and training materials' },
}[locale as 'ru' | 'ua' | 'en'] ?? { back: 'Journal', related: 'Yachting articles from', relatedSub: 'News, sailing tips and training materials' };
const formatDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString(dataLocale === 'uk' ? 'uk-UA' : dataLocale, { day: 'numeric', month: 'long', year: 'numeric' });
};
const author = post.authors?.[0]?.value;
const authorObj = author && typeof author === 'object' ? author : null;
const authorRoute = authorObj?.slug ? `/${locale}/team/${authorObj.slug}` : null;
const heroImage = (post.image as any)?.sizes?.featured?.url || (post.image as any)?.sizes?.post?.url || (post.image as any)?.url;
const heroAlt = post.imageAlt || post.name;
const tags = (post.tags || []).map((t: any) => t.value).filter(Boolean);
const allPosts = (payloadContent.entries || []).filter((e: any) => e.kind === 'post' && e.locale === post.locale && e.route !== post.route);
const tagIds = new Set(tags.map((t: any) => String(t.id)));
const relatedPosts = allPosts
  .map((p: any) => ({ post: p, score: (p.tags || []).filter((t: any) => tagIds.has(String(t.value?.id))).length }))
  .filter((r: any) => r.score > 0)
  .sort((a: any, b: any) => b.score - a.score || new Date(b.post.createdAt || 0).getTime() - new Date(a.post.createdAt || 0).getTime())
  .slice(0, 3)
  .map((r: any) => r.post);
const seo = post.seo || {};
const description = seo.meta_description || post.summary || '';
const structuredData = {
  '@context': 'https://schema.org', '@type': 'BlogPosting',
  headline: post.name, description, image: heroImage,
  datePublished: post.createdAt, dateModified: post.updatedAt,
  author: authorObj ? { '@type': 'Person', name: authorObj.name } : undefined,
  publisher: { '@type': 'Organization', name: 'Navi.training', url: 'https://navi.training' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://navi.training${post.route}` },
};
const translations = (payloadContent.entries || []).filter((e: any) => e.kind === 'post' && e.id === post.id && e.locale !== post.locale);
const languageHrefs: Record<string, string> = {};
for (const t of translations) languageHrefs[t.locale === 'uk' ? 'ua' : t.locale] = t.route;
languageHrefs[locale] = post.route;
---
<BaseLayout fullBleed title={`${post.name} — Navi.training`} description={description} locale={locale} canonical={`https://navi.training${post.route}`} image={heroImage} structuredData={structuredData} languageHrefs={languageHrefs}>
  <article class="post-page" data-navi-page="article">
    <section class="post-hero" data-evo-section="0">
      <div>
        <div>
          <a class="post-back" href={`/${locale}/blog/`}><i class="ph ph-arrow-left" aria-hidden="true"></i>{copy.back}</a>
          {tags.length ? <nav class="post-tags-inline">{tags.slice(0, 5).map((t: any) => <a href={t.route || `/${locale}/tags/${t.slug}`}>{t.name}</a>)}</nav> : null}
          <h1>{post.name}</h1>
          <div class="post-meta">
            {authorObj && <a href={authorRoute || '#'}>{authorObj.name}</a>}
            {post.createdAt && <time datetime={post.createdAt}>{formatDate(post.createdAt)}</time>}
          </div>
          {heroImage && <figure class="post-hero-photo"><img src={heroImage} alt={heroAlt} loading="eager" /></figure>}
        </div>
      </div>
    </section>
    <section class="post-body" data-evo-section="1">
      <div class="w-rich-text" set:html={renderLexical(post.content)} />
    </section>
    {relatedPosts.length ? <section class="post-related" data-evo-section="2">
      <div class="navi-blog-index">
        <header>
          <p>Navi.training</p>
          <h2>{copy.related} <span>Navi.training</span></h2>
          <span>{relatedPosts.length}</span>
        </header>
        <p class="post-related-sub">{copy.relatedSub}</p>
        <div class="navi-blog-grid">
          {relatedPosts.map((rp: any) => {
            const img = (rp.image as any)?.sizes?.card?.url || (rp.image as any)?.url;
            return <article class="navi-blog-card">
              <a href={rp.route}>
                {img && <figure><img src={img} alt={rp.imageAlt || rp.name} loading="lazy" /></figure>}
                <div class="navi-blog-card__copy">
                  {rp.createdAt && <time datetime={rp.createdAt}>{formatDate(rp.createdAt)}</time>}
                  <h3>{rp.name}</h3>
                  <span>{copy.back} <b>→</b></span>
                </div>
              </a>
            </article>;
          })}
        </div>
      </div>
    </section> : null}
  </article>
</BaseLayout>
<style is:global>
  .post-page{overflow:hidden;color:var(--navi-ink,#073746);background:var(--navi-paper,#f7faf9)}
  .post-hero{padding-top:clamp(52px,6vw,82px);background:var(--navi-paper,#f7faf9)}
  .post-hero>div{max-width:1180px;margin-inline:auto}
  .post-hero>div>div{width:min(980px,100%);margin-inline:auto}
  .post-back{display:inline-flex;align-items:center;gap:9px;color:var(--navi-ink,#073746);font-weight:700;text-decoration:none;margin-bottom:24px}
  .post-tags-inline{display:flex;gap:0;margin-bottom:20px;flex-wrap:wrap}
  .post-tags-inline a{padding:4px 0;color:#214b58;background:transparent;border:0;font-size:13px;font-weight:500;letter-spacing:0;text-decoration:none}
  .post-tags-inline a:not(:last-child)::after{content:' · ';color:#687a80}
  .post-hero h1{max-width:21ch;margin-inline:auto;color:var(--navi-ink,#073746);font:400 clamp(38px,4.4vw,58px)/1.08 'Tenor Sans',sans-serif;text-align:left}
  .post-meta{display:flex;gap:18px;align-items:center;margin-top:18px;color:#687a80;font-size:15px}
  .post-meta a{color:var(--navi-ink,#073746);font-weight:700;text-decoration:none}
  .post-meta a:hover{color:var(--navi-accent,#d97706)}
  .post-hero-photo{margin:42px 0 0;text-align:center}
  .post-hero-photo img{width:min(1000px,90vw);border-radius:18px;box-shadow:0 12px 30px rgba(7,55,70,.1)}
  .post-body{padding:0 0 clamp(60px,8vw,100px)}
  .post-body .w-rich-text{max-width:760px;margin-inline:auto;color:#173f49;font-size:clamp(18px,1.35vw,20px);line-height:1.78}
  .post-body .w-rich-text h2{margin-top:1.75em;font:400 clamp(32px,4vw,50px)/1.08 'Tenor Sans',sans-serif;color:var(--navi-ink,#073746)}
  .post-body .w-rich-text h3{margin-top:1.5em;font:400 24px/1.2 'Tenor Sans',sans-serif;color:var(--navi-ink,#073746)}
  .post-body .w-rich-text p{margin:0 0 1.3em}
  .post-body .w-rich-text a{color:var(--navi-ink,#073746);text-decoration-color:rgba(217,119,6,.62);text-decoration-line:underline;text-decoration-thickness:1px;text-underline-offset:4px}
  .post-body .w-rich-text a:hover{color:#9a5708;text-decoration-color:#9a5708}
  .post-body .w-rich-text img{width:min(1000px,90vw);max-width:none;margin-block:42px;margin-left:50%;transform:translateX(-50%);border-radius:18px}
  .post-body .w-rich-text blockquote{border-left:4px solid var(--navi-accent,#d97706);margin:1.5em 0;padding:14px 22px;background:#fff5e8;border-radius:0 14px 14px 0;font-style:italic}
  .post-body .w-rich-text ul,.post-body .w-rich-text ol{margin:0 0 1.3em;padding-left:1.5em}
  .post-body .w-rich-text li{margin:.5em 0}
  .post-body .w-rich-text code{background:var(--navi-mist,#e9f2f1);padding:2px 7px;border-radius:5px;font-size:.9em}
  .post-related{background:var(--navi-mist,#e9f2f1);padding:clamp(60px,8vw,100px) 0}
  .post-related .navi-blog-index{width:min(1380px,calc(100% - 64px))}
  .post-related .navi-blog-index>header h2 span{color:#ffb24d}
  .post-related-sub{margin:0 0 30px;color:#52656b;font-size:16px;line-height:1.5}
  @media(max-width:640px){.post-hero{padding-top:36px}.post-body .w-rich-text img{margin-left:0;transform:none;width:100%}.post-related .navi-blog-index{width:calc(100% - 32px)}}
</style>
