---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import PostFaq from '../../../components/PostFaq.astro';
import PostCta from '../../../components/PostCta.astro';
import payloadContent from '../../../data/payload-content.json';
import { renderLexical } from '../../../lib/render-lexical.mjs';

export function getStaticPaths() {
  return (payloadContent.entries || [])
    .filter((entry: any) => entry.kind === 'post')
    .map((post: any) => {
      const locale = post.locale === 'uk' ? 'ua' : post.locale;
      const slug = post.route.split('/').filter(Boolean).at(-1);
      return { params: { locale, slug }, props: { post } };
    });
}

const { post } = Astro.props;
const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const copy = {
  ru: { back: 'Бортовой журнал', minRead: 'мин. чтения' },
  ua: { back: 'Бортовий журнал', minRead: 'хв. читання' },
  en: { back: 'Journal', minRead: 'min to read' },
}[locale as 'ru' | 'ua' | 'en'] ?? { back: 'Journal', minRead: 'min to read' };

const author = post.authors?.[0]?.value;
const authorObj = author && typeof author === 'object' ? author : null;
const authorRoute = authorObj?.slug ? `/${locale}/team/${authorObj.slug}` : null;
// ponytail: author photo not populated in sync — use known static URL for Alex Burlakov
const authorPhoto = 'https://baserow-backend-production20240528124524339000000001.s3.amazonaws.com/user_files/z7mEn3jFu3gRYD2JfHFZor5pbQUpasxI_b07ee5562135e87faf19ada06196e7f9df9457c907d54cfb578401b6bd70dddc.jpg';
const heroImage = (post.image as any)?.sizes?.featured?.url || (post.image as any)?.sizes?.post?.url || (post.image as any)?.url;
const heroAlt = post.imageAlt || post.name;
const heroWidth = (post.image as any)?.sizes?.featured?.width || (post.image as any)?.width;
const heroHeight = (post.image as any)?.sizes?.featured?.height || (post.image as any)?.height;
// Build tag route lookup — post.tags[].value.slug is a CMS transliteration,
// but actual tag pages use the English slug from tag entries
const tagRoutes = new Map(
  (payloadContent.entries || [])
    .filter((e: any) => e.kind === 'tag' && e.locale === post.locale)
    .map((e: any) => [e.id, e.route])
);
const tags = (post.tags || []).map((t: any) => {
  const val = t.value;
  if (!val || typeof val !== 'object') return null;
  return { ...val, route: tagRoutes.get(val.id) || val.route || null };
}).filter(Boolean);
const faqs = post.faqs || [];
const publishDate = post.createdAt ? new Date(post.createdAt).toLocaleDateString(dataLocale === 'uk' ? 'uk-UA' : dataLocale, { day: 'numeric', month: 'long', year: 'numeric' }) : '';

function extractText(node: any): string {
  if (!node) return '';
  if (typeof node === 'string') return node;
  let text = node.text ? node.text + ' ' : '';
  if (node.root) text += extractText(node.root);
  for (const child of node.children || []) text += extractText(child);
  return text;
}
const readTime = Math.max(1, Math.round(extractText(post.content).split(/\s+/).length / 200));

const latestPosts = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'post' && e.locale === post.locale && e.route !== post.route)
  .sort((a: any, b: any) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime())
  .slice(0, 3);
const seo = post.seo || {};
const description = seo.meta_description || post.summary || '';
const structuredData = {
  '@context': 'https://schema.org', '@type': 'BlogPosting',
  headline: post.name, description, image: heroImage,
  datePublished: post.createdAt, dateModified: post.updatedAt,
  author: authorObj ? { '@type': 'Person', name: authorObj.name } : undefined,
  publisher: { '@type': 'Organization', name: 'Navi.training', url: 'https://navi.training' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://navi.training${post.route}` },
};
const translations = (payloadContent.entries || []).filter((e: any) => e.kind === 'post' && e.id === post.id && e.locale !== post.locale);
const languageHrefs: Record<string, string> = {};
for (const t of translations) languageHrefs[t.locale === 'uk' ? 'ua' : t.locale] = t.route;
languageHrefs[locale] = post.route;
---
<BaseLayout fullBleed title={`${post.name} — Navi.training`} description={description} locale={locale} canonical={`https://navi.training${post.route}`} image={heroImage} structuredData={structuredData} languageHrefs={languageHrefs}>
  <article class="post-page" data-navi-page="article">
    <header class="post-header">
      <div class="post-header__inner">
        <h1>{post.name}</h1>
        {tags.length ? <div class="post-header__tags">{tags.map((t: any) => <a href={t.route || `/${locale}/tags/${t.slug}`}>{t.name}</a>)}</div> : null}
        <div class="post-header__meta">
          {authorObj && (
            <a class="post-header__author" href={authorRoute || '#'}>
              <img class="post-header__avatar" src={authorPhoto} alt={authorObj.name} width="40" height="40" loading="eager" />
              {authorObj.name}
            </a>
          )}
          <span class="post-header__time">
            <img src="/cgi/asset/65f9715a5565847069a10a86_clock_wbbL_tR7VzDK4DZGIj3rp.svg" alt="" width="24" height="24" />
            {readTime} {copy.minRead}
          </span>
        </div>
      </div>
    </header>
    {heroImage && <figure class="post-cover"><img src={heroImage} alt={heroAlt} width={heroWidth} height={heroHeight} loading="eager" /></figure>}
    <section class="post-body">
      <div class="post-body__inner">
        <div class="post-prose" set:html={renderLexical(post.content)} />
        {authorObj && (
          <a class="post-author-card" href={authorRoute || '#'}>
            <img class="post-author-card__avatar" src={authorPhoto} alt={authorObj.name} width="48" height="48" loading="lazy" />
            <div class="post-author-card__info">
              <span class="post-author-card__name">{authorObj.name}</span>
              {publishDate && <time class="post-author-card__date" datetime={post.createdAt}>{publishDate}</time>}
            </div>
          </a>
        )}
        <div class="post-body__cta">
          <PostCta locale={locale} />
        </div>
      </div>
    </section>
    {faqs.length > 0 && <PostFaq faqs={faqs} locale={locale} />}
    <RelatedPosts posts={latestPosts} locale={locale} />
  </article>
</BaseLayout>
<style>
  .post-page{color:var(--ds-ink,#073746);background:var(--ds-paper,#f7faf9)}
  /* Header — white bg, centered */
  .post-header{padding:clamp(60px,10vw,120px) 24px clamp(32px,5vw,48px);text-align:center;background:#fff}
  .post-header__inner{max-width:860px;margin-inline:auto}
  .post-header h1{margin:0 0 24px;font:400 clamp(32px,5vw,56px)/1.08 'Tenor Sans',sans-serif;letter-spacing:-.02em;text-transform:uppercase;color:var(--ds-ink,#073746)}
  /* Tags as pills */
  .post-header__tags{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:28px}
  .post-header__tags a{display:inline-block;padding:8px 16px;color:#fff;background:#ffb052;border-radius:5px;font:700 12px/1 Arial,sans-serif;letter-spacing:.06em;text-transform:capitalize;text-decoration:none;transition:background .15s}
  .post-header__tags a:hover{background:#e89a3a}
  /* Author row */
  .post-header__meta{display:flex;align-items:center;justify-content:center;gap:24px;margin-top:4px}
  .post-header__author{display:inline-flex;align-items:center;gap:10px;color:var(--ds-ink,#073746);font:500 15px/1.2 Arial,sans-serif;text-decoration:none}
  .post-header__author:hover{color:#ffb052}
  .post-header__avatar{width:40px;height:40px;border-radius:50%;object-fit:cover}
  .post-header__time{display:inline-flex;align-items:center;gap:6px;color:#52656b;font-size:14px}
  .post-header__time img{width:24px;height:24px}
  /* Cover image */
  .post-cover{width:min(860px,calc(100% - 48px));margin:0 auto 0;padding:0}
  .post-cover img{width:100%;border-radius:18px;object-fit:cover}
  /* Body */
  .post-body{background:#fff;padding:clamp(40px,6vw,72px) 24px}
  .post-body__inner{max-width:760px;margin-inline:auto}
  .post-prose{font-size:18px;line-height:1.8;color:#234550}
  .post-prose :global(h2){margin:2em 0 .6em;font:400 clamp(28px,4vw,40px)/1.12 'Tenor Sans',sans-serif;letter-spacing:-.02em;color:var(--ds-ink)}
  .post-prose :global(h3){margin:1.8em 0 .5em;font:400 24px/1.2 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .post-prose :global(p){margin:0 0 1.3em}
  .post-prose :global(a){color:#164e61;text-decoration-color:rgba(217,119,6,.6);text-decoration-thickness:1px;text-underline-offset:4px}
  .post-prose :global(a:hover){color:#9a5708}
  .post-prose :global(blockquote){border-left:4px solid var(--ds-accent,#d97706);margin:1.5em 0;padding:14px 22px;background:#fff5e8;border-radius:0 14px 14px 0;font-size:18px;font-style:italic}
  .post-prose :global(ul),.post-prose :global(ol){margin:0 0 1.3em;padding-left:1.5em}
  .post-prose :global(li){margin:.5em 0}
  .post-prose :global(figure){margin:1.8em 0}
  .post-prose :global(img){width:100%;border-radius:var(--ds-radius-card,18px);box-shadow:var(--ds-shadow-card)}
  .post-prose :global(code){background:var(--ds-mist,#e9f2f1);padding:2px 7px;border-radius:5px;font-size:.9em}
  .post-body__cta{margin-top:68px;margin-bottom:60px}
  .post-author-card{display:flex;align-items:center;gap:14px;padding:18px 0;border-top:1px solid var(--ds-line,rgba(7,55,70,.12));text-decoration:none;color:var(--ds-ink,#073746);transition:color .15s}
  .post-author-card:hover{color:#ffb052}
  .post-author-card__avatar{width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0}
  .post-author-card__info{display:flex;flex-direction:column;gap:2px}
  .post-author-card__name{font:600 15px/1.2 Arial,sans-serif}
  .post-author-card__date{color:#52656b;font-size:13px}
  @media(max-width:640px){.post-cover{width:calc(100% - 24px)}.post-header__meta{flex-direction:column;gap:12px}}
</style>
