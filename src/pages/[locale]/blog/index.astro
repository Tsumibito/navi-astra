---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PhotoStrip from '../../../components/PhotoStrip.astro';
import payloadContent from '../../../data/payload-content.json';

export function getStaticPaths() {
  return ['ru', 'ua', 'en'].map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const posts = (payloadContent.entries || [])
  .filter((entry: any) => entry.kind === 'post' && entry.locale === dataLocale)
  .sort((a: any, b: any) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());
const copy = {
  ru: { heroTitle: 'Блог', heroSub: 'Яхтенные новости, лайфхаки, и масса интересного', freshKicker: 'БОРТОВОЙ ЖУРНАЛ', freshTitle: 'Свежие истории', read: 'Читать историю', coord: '46.1603° N  ·  1.1511° W' },
  ua: { heroTitle: 'Блог', heroSub: 'Яхтові новини, лайфхаки та маса цікавого', freshKicker: 'БОРТОВИЙ ЖУРНАЛ', freshTitle: 'Свіжі історії', read: 'Читати історію', coord: '46.1603° N  ·  1.1511° W' },
  en: { heroTitle: 'Blog', heroSub: 'Yachting news, tips and plenty of inspiration', freshKicker: 'SHIP\'S LOG', freshTitle: 'Latest stories', read: 'Read story', coord: '46.1603° N  ·  1.1511° W' },
}[locale as 'ru' | 'ua' | 'en'] ?? { heroTitle: 'Blog', heroSub: 'Yachting news, tips and plenty of inspiration', freshKicker: 'SHIP\'S LOG', freshTitle: 'Latest stories', read: 'Read story', coord: '46.1603° N  ·  1.1511° W' };
const dateFmt = (iso: string) => new Date(iso).toLocaleDateString(dataLocale === 'uk' ? 'uk-UA' : dataLocale, { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout fullBleed title={`${copy.heroTitle} Navi.training — Navi.training`} description={copy.heroSub} locale={locale} canonical={`https://navi.training/${locale}/blog/`} languageHrefs={{ ru: '/ru/blog/', ua: '/ua/blog/', en: '/en/blog/' }}>
  <div class="blog-page">
    {/* Hero */}
    <section class="blog-hero">
      <div class="blog-hero__inner">
        <header>
          <h1>{copy.heroTitle}<span> Navi.training</span></h1>
          <p>{copy.heroSub}</p>
        </header>
      </div>
    </section>
    {/* Photo strip */}
    <PhotoStrip />
    {/* Post grid */}
    <section class="navi-blog-index">
      <header>
        <p>{copy.freshKicker}</p>
        <h2>{copy.freshTitle}</h2>
        <span>{copy.coord}</span>
      </header>
      <div class="navi-blog-grid">
        {posts.map((post: any) => {
          const img = (post.image as any)?.sizes?.card?.url || (post.image as any)?.sizes?.featured?.url || (post.image as any)?.url;
          return <article class="navi-blog-card">
            <a href={post.route}>
              <figure>{img && <img src={img} alt={post.imageAlt || post.name} loading="lazy" />}</figure>
              <div class="navi-blog-card__copy">
                {post.createdAt && <time datetime={post.createdAt}>{dateFmt(post.createdAt)}</time>}
                <h3>{post.name}</h3>
                {post.summary && <p>{post.summary}</p>}
                <span>{copy.read}<b aria-hidden="true">→</b></span>
              </div>
            </a>
          </article>;
        })}
      </div>
    </section>
  </div>
</BaseLayout>
<style>
  /* Hero — cinematic photo background, left-aligned text */
  .blog-hero{position:relative;min-height:430px;isolation:isolate;overflow:hidden;background:linear-gradient(90deg,rgba(3,35,46,.88),rgba(3,35,46,.28)),url('/cgi/asset/65fecaed1ad009d27a4a41ce_l1_ATycUs4suoYYnQmvJibP4.jpg') center 54%/cover no-repeat}
  .blog-hero::after{content:"46.1603° N  ·  1.1511° W";position:absolute;right:max(24px,calc((100vw - 1180px)/2));bottom:28px;color:rgba(255,255,255,.82);font:700 11px/1.2 ui-monospace,monospace;letter-spacing:.13em}
  .blog-hero__inner{display:flex;width:min(1180px,calc(100% - 40px));min-height:430px;margin:0 auto;padding:76px 0 58px;align-items:flex-end;justify-content:flex-start;box-sizing:border-box}
  .blog-hero header{width:min(660px,100%);margin:0;padding:0;text-align:left}
  .blog-hero h1{margin:0 0 18px;color:#fff;font:400 clamp(50px,7vw,92px)/.96 'Tenor Sans',sans-serif}
  .blog-hero h1 span{color:#ffb24d}
  .blog-hero p{max-width:34ch;margin:0;color:rgba(255,255,255,.9);font-size:clamp(18px,2vw,24px);line-height:1.35}
  /* ponytail: navi-evolution-v1.css scopes grid to body[data-navi-page], duplicate here for native pages */
  .navi-blog-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:34px 22px}
  @media(max-width:900px){.navi-blog-grid{grid-template-columns:1fr 1fr}.navi-blog-card:first-child{grid-column:1/-1}.navi-blog-card:first-child a{grid-template-columns:1fr 1fr}}
  @media(max-width:640px){.blog-hero,.blog-hero__inner{min-height:360px}.blog-hero__inner{padding-bottom:46px}.blog-hero::after{bottom:18px}.navi-blog-grid{grid-template-columns:1fr}.navi-blog-card:first-child{grid-column:auto}.navi-blog-card:first-child a{grid-template-columns:1fr}.navi-blog-card:first-child figure,.navi-blog-card:first-child img{min-height:250px;height:250px}}
</style>
