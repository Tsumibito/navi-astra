---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import payloadContent from '../../../data/payload-content.json';
const content = payloadContent as unknown as { encyclopedia?: any[] };

export function getStaticPaths() {
  return ['ru', 'ua', 'en'].map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const terms = (content.encyclopedia || []).filter((term) => term.locale === dataLocale);
const copy = {
  ru: { title: 'Яхтенная энциклопедия Navi.training', intro: 'Понятные определения морских и яхтенных терминов, подготовленные на основе профессиональных источников и практики.', empty: 'Первые статьи готовятся к публикации.' },
  ua: { title: 'Яхтова енциклопедія Navi.training', intro: 'Зрозумілі визначення морських і яхтових термінів, підготовлені на основі професійних джерел і практики.', empty: 'Перші статті готуються до публікації.' },
  en: { title: 'Navi.training Yachting Encyclopedia', intro: 'Clear explanations of sailing and maritime terminology, grounded in professional sources and practical seamanship.', empty: 'The first entries are being prepared.' },
}[locale];
---
<BaseLayout title={copy.title} description={copy.intro} locale={locale}>
  <section class="encyclopedia-shell">
    <header class="encyclopedia-hero"><p class="eyebrow">Navi.training</p><h1>{copy.title}</h1><p>{copy.intro}</p></header>
    {terms.length ? <div class="term-grid">{terms.map((term) => <article class="term-card"><i class="ph ph-compass-rose" aria-hidden="true"></i><p class="term-domain">{term.domain}</p><h2><a href={term.route}>{term.term}<i class="ph ph-arrow-up-right" aria-hidden="true"></i></a></h2><p>{term.definition}</p>{term.aliases?.length ? <p class="aliases">{term.aliases.join(' · ')}</p> : null}</article>)}</div> : <p class="empty">{copy.empty}</p>}
  </section>
</BaseLayout>
<style>
  .encyclopedia-shell{max-width:1120px;margin:0 auto;padding:44px 0 80px}.encyclopedia-hero{max-width:820px;margin-bottom:44px}.eyebrow,.term-domain{color:#d97706;text-transform:uppercase;letter-spacing:.12em;font-size:.78rem}.encyclopedia-hero h1{font-family:'Tenor Sans',sans-serif;font-size:clamp(2.3rem,6vw,4.8rem);line-height:1.05;margin:.35rem 0 1rem}.encyclopedia-hero>p:last-child{font-size:1.15rem;line-height:1.65;color:#46515a}.term-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:20px}.term-card{position:relative;border:1px solid #dce5e9;border-radius:18px;padding:26px;background:linear-gradient(145deg,#fff,#f4fafc);box-shadow:0 12px 34px rgba(18,53,65,.07)}.term-card>.ph{position:absolute;top:24px;right:24px;color:#77a9b8;font-size:1.45rem}.term-card h2{font-size:1.55rem;margin:.4rem 0 .75rem}.term-card h2 a{display:flex;gap:.5rem;align-items:center;color:#102e39;text-decoration:none}.term-card h2 .ph{font-size:1rem}.term-card a:hover{color:#b86405}.term-card p{line-height:1.55}.aliases{color:#68777d;font-size:.9rem}.empty{padding:40px;border-radius:18px;background:#eef7fb}
</style>
