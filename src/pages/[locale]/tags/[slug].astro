---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import payloadContent from '../../../data/payload-content.json';
import { renderLexical } from '../../../lib/render-lexical.mjs';

export function getStaticPaths() {
  const locales = ['ru', 'ua', 'en'];
  return locales.flatMap((locale) => {
    const dataLocale = locale === 'ua' ? 'uk' : locale;
    const tags = (payloadContent.entries || []).filter((e: any) => e.kind === 'tag' && e.locale === dataLocale);
    return tags.map((tag) => ({
      params: { locale, slug: tag.route?.split('/').filter(Boolean).pop() },
      props: { tagId: tag.id },
    }));
  });
}

const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const tagId = Astro.props.tagId;
const tag = (payloadContent.entries || []).find((e: any) => e.kind === 'tag' && e.locale === dataLocale && e.id === tagId);
if (!tag) return Astro.redirect('/404');

const posts = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'post' && e.locale === dataLocale && (e.tags || []).some((t: any) => t?.value?.id === tagId))
  .sort((a: any, b: any) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());

const allTags = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'tag' && e.locale === dataLocale && e.id !== tagId)
  .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''));

const latestPosts = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'post' && e.locale === dataLocale)
  .sort((a: any, b: any) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime())
  .slice(0, 3);

const copy = {
  ru: { articlesByTag: 'Статьи по тегу', tagCloud: 'Облако тегов', read: 'Читать историю', kicker: 'БОРТОВОЙ ЖУРНАЛ', coord: '46.1603° N  ·  1.1511° W' },
  ua: { articlesByTag: 'Статті за тегом', tagCloud: 'Хмара тегів', read: 'Читати історію', kicker: 'БОРТОВИЙ ЖУРНАЛ', coord: '46.1603° N  ·  1.1511° W' },
  en: { articlesByTag: 'Articles by tag', tagCloud: 'Tag cloud', read: 'Read story', kicker: 'SHIP\'S LOG', coord: '46.1603° N  ·  1.1511° W' },
}[locale as 'ru' | 'ua' | 'en'] ?? { articlesByTag: 'Articles by tag', tagCloud: 'Tag cloud', read: 'Read story', kicker: 'SHIP\'S LOG', coord: '46.1603° N  ·  1.1511° W' };

const dateFmt = (iso: string) => new Date(iso).toLocaleDateString(dataLocale === 'uk' ? 'uk-UA' : dataLocale, { day: 'numeric', month: 'long', year: 'numeric' });
const tagImage = tag.image && typeof tag.image === 'object' ? (tag.image.sizes?.featured?.url || tag.image.url) : null;
const firstPostImage = posts[0]?.image && typeof posts[0].image === 'object'
  ? (posts[0].image.sizes?.featured?.url || posts[0].image.url)
  : null;
const heroBg = tagImage || firstPostImage;
const heroAlt = tag.imageAlt || tag.name;
const seo = tag.seo || {};
const langHrefs: Record<string, string> = {};
['ru', 'ua', 'en'].forEach((l) => {
  const dl = l === 'ua' ? 'uk' : l;
  const t = (payloadContent.entries || []).find((e: any) => e.kind === 'tag' && e.locale === dl && e.id === tagId);
  if (t) langHrefs[l] = t.route;
});
---
<BaseLayout fullBleed title={`${seo.title || tag.name} — Navi.training`} description={seo.meta_description || tag.summary || ''} locale={locale} canonical={`https://navi.training${tag.route}`} image={heroBg} languageHrefs={langHrefs} structuredData={{"@context":"https://schema.org","@type":"CollectionPage","name":tag.name,"description":tag.summary,"url":`https://navi.training${tag.route}`}}>
  <article class="tag-page" data-navi-page="tag">
    {/* 1. Cinematic hero */}
    <section class="tag-hero" aria-label={tag.name}>
      {heroBg && <img class="tag-hero__bg" src={heroBg} alt={heroAlt} loading="eager" fetchpriority="high" decoding="async" />}
      <div class="tag-hero__inner">
        <header>
          <h1>{tag.name}</h1>
          {tag.summary && <p>{tag.summary}</p>}
        </header>
        <span class="tag-hero__coord" aria-hidden="true">{copy.coord}</span>
      </div>
    </section>
    {/* 2. Articles by tag */}
    {posts.length > 0 && (
      <section class="tag-articles">
        <div class="tag-articles__inner">
          <header>
            <p>{copy.kicker}</p>
            <h2>{copy.articlesByTag}: {tag.name}</h2>
            <span>{copy.coord}</span>
          </header>
          <div class="navi-blog-grid">
            {posts.map((post: any) => {
              const img = (post.image as any)?.sizes?.card?.url || (post.image as any)?.url;
              return <article class="navi-blog-card">
                <a href={post.route}>
                  <figure>{img && <img src={img} alt={post.imageAlt || post.name} loading="lazy" />}</figure>
                  <div class="navi-blog-card__copy">
                    {post.createdAt && <time datetime={post.createdAt}>{dateFmt(post.createdAt)}</time>}
                    <h3>{post.name}</h3>
                    {post.summary && <p>{post.summary}</p>}
                    <span>{copy.read}<b aria-hidden="true">→</b></span>
                  </div>
                </a>
              </article>;
            })}
          </div>
        </div>
      </section>
    )}
    {/* 3. Tag body content */}
    {tag.content && (
      <section class="tag-body">
        <div class="tag-body__inner">
          <div class="tag-prose" set:html={renderLexical(tag.content)} />
        </div>
      </section>
    )}
    {/* 4. Tag cloud */}
    {allTags.length > 0 && (
      <section class="tag-cloud">
        <div class="tag-cloud__inner">
          <h2>{copy.tagCloud}</h2>
          <div class="tag-cloud__list">
            {allTags.map((t: any) => <a href={t.route}>{t.name}</a>)}
          </div>
        </div>
      </section>
    )}
    {/* 5. Three latest posts (same component as tags index) */}
    {latestPosts.length > 0 && <RelatedPosts posts={latestPosts} locale={locale} />}
  </article>
</BaseLayout>
<style>
  .tag-hero{position:relative;isolation:isolate;min-height:360px;overflow:hidden;background:linear-gradient(90deg,#03232ee0,#03232e47),#073746}
  .tag-hero__bg{position:absolute;inset:0;z-index:-2;width:100%;height:100%;object-fit:cover;display:block}
  .tag-hero::after{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(90deg,#03232ee0,#03232e47)}
  .tag-hero__inner{display:flex;flex-direction:column;justify-content:flex-end;width:min(1180px,calc(100% - 40px));min-height:400px;margin:0 auto;padding:92px 0 72px;box-sizing:border-box;position:relative;z-index:1}
  .tag-hero header{max-width:720px}
  .tag-hero h1{margin:0 0 22px;color:#fff;font:400 clamp(40px,6vw,72px)/.96 'Tenor Sans',sans-serif}
  .tag-hero p{max-width:52ch;margin:0 0 38px;color:rgba(255,255,255,.9);font-size:clamp(16px,2vw,22px);line-height:1.5}
  .tag-hero__coord{position:absolute;bottom:32px;right:0;color:rgba(255,255,255,.82);font:700 11px/1.2 ui-monospace,monospace;letter-spacing:.1em}
  @media(max-width:640px){.tag-hero,.tag-hero__inner{min-height:340px;padding:72px 0 56px}.tag-hero h1{margin-bottom:16px}.tag-hero p{margin-bottom:28px}.tag-hero__coord{bottom:22px;right:20px}}

  .tag-articles{width:100%;background:#fff;border-radius:var(--ds-radius-section-top,60px 60px 0 0);margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:2;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25));padding:84px 24px 132px;box-sizing:border-box}
  .tag-articles__inner{max-width:1180px;margin:0 auto}
  .tag-articles__inner > header{display:grid;grid-template-columns:1fr auto;align-items:end;margin-bottom:30px;padding-bottom:22px;border-bottom:1px solid var(--navi-line,rgba(7,55,70,.12))}
  .tag-articles__inner > header p{grid-column:1 / -1;margin:0 0 10px;color:#52656b;font:700 11px/1.3 Arial,sans-serif;letter-spacing:.15em;text-transform:uppercase}
  .tag-articles__inner > header h2{margin:0;color:var(--ds-ink,#073746);font-size:clamp(42px,5vw,68px);line-height:1}
  .tag-articles__inner > header span{padding-bottom:7px;color:var(--navi-accent,#d97706);font:700 11px/1.2 ui-monospace,monospace;letter-spacing:.1em}
  .navi-blog-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:34px 22px}
  @media(max-width:900px){.tag-articles__inner > header{grid-template-columns:1fr 1fr}.navi-blog-grid{grid-template-columns:1fr 1fr}.navi-blog-card:first-child{grid-column:1/-1}.navi-blog-card:first-child a{grid-template-columns:1fr 1fr}}
  @media(max-width:640px){.tag-articles{border-radius:36px 36px 0 0;margin-top:calc(-1 * var(--ds-section-overlap-mobile,36px));padding:60px 16px 92px}.tag-articles__inner > header{grid-template-columns:1fr;gap:10px}.tag-articles__inner > header span{padding:0}.navi-blog-grid{grid-template-columns:1fr}.navi-blog-card:first-child{grid-column:auto}.navi-blog-card:first-child a{grid-template-columns:1fr}.navi-blog-card:first-child figure,.navi-blog-card:first-child img{min-height:250px;height:250px}}

  .tag-body{width:100%;background:var(--ds-paper,#f7faf9);border-radius:var(--ds-radius-section-top,60px 60px 0 0);margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:3;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25));padding:84px 24px 132px;box-sizing:border-box}
  .tag-body__inner{max-width:760px;margin:0 auto}
  .tag-prose{font-size:18px;line-height:1.8;color:#234550}
  .tag-prose :global(h2){margin:1.8em 0 .6em;font:400 clamp(26px,3vw,36px)/1.15 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .tag-prose :global(h3){margin:1.6em 0 .5em;font:400 22px/1.2 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .tag-prose :global(p){margin:0 0 1.3em}
  .tag-prose :global(a){color:#164e61;text-decoration-color:rgba(217,119,6,.6);text-decoration-thickness:1px;text-underline-offset:4px}
  .tag-prose :global(a:hover){color:#9a5708}
  .tag-prose :global(ul),.tag-prose :global(ol){margin:0 0 1.3em;padding-left:1.5em}
  .tag-prose :global(li){margin:.5em 0}
  @media(max-width:640px){.tag-body{border-radius:36px 36px 0 0;margin-top:calc(-1 * var(--ds-section-overlap-mobile,36px));padding:60px 16px 92px}}

  .tag-cloud{width:100%;background:#fff;border-radius:var(--ds-radius-section-top,60px 60px 0 0);margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:4;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25));padding:84px 24px 132px;box-sizing:border-box}
  .tag-cloud__inner{max-width:1180px;margin:0 auto}
  .tag-cloud h2{margin:0 0 26px;font:400 clamp(28px,3.5vw,42px)/1.15 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .tag-cloud__list{display:flex;flex-wrap:wrap;gap:8px}
  .tag-cloud__list a{display:inline-block;padding:8px 16px;color:#fff;background:#ffb052;border-radius:5px;font:700 12px/1 Arial,sans-serif;letter-spacing:.06em;text-transform:capitalize;text-decoration:none;transition:background .15s}
  .tag-cloud__list a:hover{background:#e89a3a}
  @media(max-width:640px){.tag-cloud{border-radius:36px 36px 0 0;margin-top:calc(-1 * var(--ds-section-overlap-mobile,36px));padding:60px 16px 92px}}
</style>
