---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import payloadContent from '../../../data/payload-content.json';
import { renderLexical } from '../../../lib/render-lexical.mjs';

export function getStaticPaths() {
  const locales = ['ru', 'ua', 'en'];
  return locales.flatMap((locale) => {
    const dataLocale = locale === 'ua' ? 'uk' : locale;
    const tags = (payloadContent.entries || []).filter((e: any) => e.kind === 'tag' && e.locale === dataLocale);
    return tags.map((tag) => ({
      params: { locale, slug: tag.route?.split('/').filter(Boolean).pop() },
      props: { tagId: tag.id },
    }));
  });
}

const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const tagId = Astro.props.tagId;
const tag = (payloadContent.entries || []).find((e: any) => e.kind === 'tag' && e.locale === dataLocale && e.id === tagId);
if (!tag) return Astro.redirect('/404');

const posts = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'post' && e.locale === dataLocale && (e.tags || []).some((t: any) => t?.value?.id === tagId))
  .sort((a: any, b: any) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());

const allTags = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'tag' && e.locale === dataLocale && e.id !== tagId)
  .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''));

const copy = {
  ru: { articlesByTag: 'Статьи по тегу', tagCloud: 'Облако тегов' },
  ua: { articlesByTag: 'Статті за тегом', tagCloud: 'Хмара тегів' },
  en: { articlesByTag: 'Articles by tag', tagCloud: 'Tag cloud' },
}[locale as 'ru' | 'ua' | 'en'] ?? { articlesByTag: 'Articles by tag', tagCloud: 'Tag cloud' };

const tagImage = tag.image && typeof tag.image === 'object' ? (tag.image.sizes?.featured?.url || tag.image.url) : null;
const seo = tag.seo || {};
const langHrefs: Record<string, string> = {};
['ru', 'ua', 'en'].forEach((l) => {
  const dl = l === 'ua' ? 'uk' : l;
  const t = (payloadContent.entries || []).find((e: any) => e.kind === 'tag' && e.locale === dl && e.id === tagId);
  if (t) langHrefs[l] = t.route;
});
---
<BaseLayout fullBleed title={`${seo.title || tag.name} — Navi.training`} description={seo.meta_description || tag.summary || ''} locale={locale} canonical={`https://navi.training${tag.route}`} languageHrefs={langHrefs} structuredData={{"@context":"https://schema.org","@type":"CollectionPage","name":tag.name,"description":tag.summary,"url":`https://navi.training${tag.route}`}}>
  <article class="tag-page" data-navi-page="tag">
    {/* 1. Hero: name + summary + image */}
    <section class="tag-hero">
      <div class="tag-hero__inner">
        <header>
          <h1>{tag.name}</h1>
          {tag.summary && <p>{tag.summary}</p>}
        </header>
        {tagImage && <figure><img src={tagImage} alt={tag.imageAlt || tag.name} loading="eager" /></figure>}
      </div>
    </section>
    {/* 2. Articles by tag */}
    {posts.length > 0 && (
      <section class="tag-articles">
        <div class="tag-articles__inner">
          <h2>{copy.articlesByTag}: {tag.name}</h2>
          <div class="tag-articles__grid">
            {posts.map((post: any) => {
              const img = (post.image as any)?.sizes?.card?.url || (post.image as any)?.url;
              return <a class="tag-post-card" href={post.route}>
                {img && <figure><img src={img} alt={post.imageAlt || post.name} loading="lazy" /></figure>}
                <span>{post.name}</span>
              </a>;
            })}
          </div>
        </div>
      </section>
    )}
    {/* 3. Tag body content */}
    {tag.content && (
      <section class="tag-body">
        <div class="tag-body__inner">
          <div class="tag-prose" set:html={renderLexical(tag.content)} />
        </div>
      </section>
    )}
    {/* 4. Tag cloud */}
    {allTags.length > 0 && (
      <section class="tag-cloud">
        <div class="tag-cloud__inner">
          <h2>{copy.tagCloud}</h2>
          <div class="tag-cloud__list">
            {allTags.map((t: any) => <a href={t.route}>{t.name}</a>)}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>
<style>
  .tag-hero{position:relative;min-height:320px;background:linear-gradient(90deg,rgba(3,35,46,.88),rgba(3,35,46,.28)),#073746;color:#fff;padding:clamp(60px,8vw,120px) 24px clamp(40px,5vw,72px);overflow:hidden}
  .tag-hero__inner{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center}
  .tag-hero h1{margin:0 0 18px;font:400 clamp(36px,5vw,64px)/1.05 'Tenor Sans',sans-serif}
  .tag-hero p{max-width:52ch;margin:0;color:rgba(255,255,255,.9);font-size:clamp(16px,2vw,20px);line-height:1.5}
  .tag-hero figure{margin:0;max-width:360px}
  .tag-hero img{width:100%;border-radius:18px;object-fit:cover}
  @media(max-width:640px){.tag-hero__inner{grid-template-columns:1fr}.tag-hero figure{max-width:100%}}

  .tag-articles{background:#fff;padding:clamp(40px,6vw,80px) 24px}
  .tag-articles__inner{max-width:1180px;margin:0 auto}
  .tag-articles h2{margin:0 0 30px;font:400 clamp(28px,3.5vw,42px)/1.15 'Tenor Sans',sans-serif;color:var(--ds-ink,#073746)}
  .tag-articles__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:24px}
  .tag-post-card{display:block;overflow:hidden;border-radius:18px;background:#fff;box-shadow:0 8px 28px rgba(20,45,60,.12);text-decoration:none;color:var(--ds-ink,#073746);transition:box-shadow .2s,transform .2s}
  .tag-post-card:hover{box-shadow:0 18px 44px rgba(7,55,70,.12);transform:translateY(-3px)}
  .tag-post-card figure{margin:0;overflow:hidden;background:var(--ds-mist,#e9f2f1)}
  .tag-post-card img{width:100%;aspect-ratio:16/10;object-fit:cover;display:block}
  .tag-post-card span{display:block;padding:16px 18px;font:500 16px/1.25 Arial,sans-serif}
  @media(max-width:900px){.tag-articles__grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  @media(max-width:640px){.tag-articles__grid{grid-template-columns:1fr}}

  .tag-body{background:var(--ds-paper,#f7faf9);padding:clamp(40px,6vw,80px) 24px}
  .tag-body__inner{max-width:760px;margin:0 auto}
  .tag-prose{font-size:18px;line-height:1.8;color:#234550}
  .tag-prose :global(h2){margin:1.8em 0 .6em;font:400 clamp(26px,3vw,36px)/1.15 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .tag-prose :global(h3){margin:1.6em 0 .5em;font:400 22px/1.2 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .tag-prose :global(p){margin:0 0 1.3em}
  .tag-prose :global(a){color:#164e61;text-decoration-color:rgba(217,119,6,.6);text-decoration-thickness:1px;text-underline-offset:4px}
  .tag-prose :global(a:hover){color:#9a5708}
  .tag-prose :global(ul),.tag-prose :global(ol){margin:0 0 1.3em;padding-left:1.5em}
  .tag-prose :global(li){margin:.5em 0}

  .tag-cloud{background:#fff;padding:clamp(40px,6vw,80px) 24px}
  .tag-cloud__inner{max-width:1180px;margin:0 auto}
  .tag-cloud h2{margin:0 0 26px;font:400 clamp(28px,3.5vw,42px)/1.15 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .tag-cloud__list{display:flex;flex-wrap:wrap;gap:10px}
  .tag-cloud__list a{display:inline-block;padding:10px 16px;border-radius:20px;background:var(--ds-mist,#e9f2f1);color:var(--ds-ink,#073746);font:600 14px/1 Arial,sans-serif;text-decoration:none;transition:background .15s,color .15s}
  .tag-cloud__list a:hover{background:var(--ds-accent,#d97706);color:#fff}
</style>
