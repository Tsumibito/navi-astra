---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import payloadContent from '../../../data/payload-content.json';
import { renderLexical } from '../../../lib/render-lexical.mjs';

export function getStaticPaths() {
  return (payloadContent.entries || []).filter((entry) => entry.kind === 'author').map((author) => {
    const [, locale, , slug] = author.route.split('/');
    return { params: { locale, slug }, props: { author } };
  });
}

const { author } = Astro.props;
const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const authorTranslations = (payloadContent.entries || []).filter((entry) => entry.kind === 'author' && entry.id === author.id);
const languageHrefs = Object.fromEntries(authorTranslations.map((entry) => [entry.locale === 'uk' ? 'ua' : entry.locale, entry.route]));
const relatedPosts = (payloadContent.entries || []).filter((entry) => {
  if (entry.kind !== 'post' || entry.locale !== dataLocale) return false;
  if ((author.postIds || []).map(String).includes(String(entry.id))) return true;
  return (entry.authors || []).some((relation) => String(relation?.value?.id ?? relation?.value ?? relation?.id ?? relation) === String(author.id));
}).sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime()).slice(0, 6);
const copy = {
  ru: { crew: 'Команда Navi.training', bio: 'Опыт и подход', articles: 'Статьи автора', read: 'Читать статью', back: 'Вся команда', contact: 'Связаться', journal: 'Судовой журнал' },
  ua: { crew: 'Команда Navi.training', bio: 'Досвід і підхід', articles: 'Статті автора', read: 'Читати статтю', back: 'Уся команда', contact: 'Зв’язатися', journal: 'Судновий журнал' },
  en: { crew: 'The Navi.training crew', bio: 'Experience and approach', articles: 'Articles by this author', read: 'Read article', back: 'Meet the crew', contact: 'Contact', journal: "Ship's log" },
}[locale];
const description = author.seo?.meta_description || author.seo?.metaDescription || author.summary || author.position || author.name;
const photo = author.image?.sizes?.post?.url || author.image?.sizes?.card?.url || author.image?.url;
const socialLinks = (author.links || []).filter((link) => link?.url);
const iconByService = { email: 'ph-envelope-simple', phone: 'ph-phone', x: 'ph-x-logo', facebook: 'ph-facebook-logo', instagram: 'ph-instagram-logo', linkedin: 'ph-linkedin-logo', github: 'ph-github-logo', website: 'ph-globe' };
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ProfilePage', url: `https://navi.training${author.route}`,
  mainEntity: { '@type': 'Person', name: author.name, jobTitle: author.position || undefined, description, image: photo || undefined, url: `https://navi.training${author.route}`, sameAs: socialLinks.filter((link) => /^https?:/.test(link.url)).map((link) => link.url) },
};
---
<BaseLayout title={`${author.name} — Navi.training`} description={description} locale={locale} canonical={`https://navi.training${author.route}`} image={photo} structuredData={structuredData} languageHrefs={languageHrefs}>
  <article class="profile">
    <a class="profile-back" href={`/${locale}/team`}><i class="ph ph-arrow-left"></i>{copy.back}</a>
    <header class="profile-hero">
      <figure class="profile-photo">{photo ? <img src={photo} alt={author.image?.alt || author.name} /> : <i class="ph ph-user-circle"></i>}<span aria-hidden="true"></span></figure>
      <div class="profile-intro">
        <p class="profile-eyebrow">{copy.crew}</p>
        <h1>{author.name}</h1>
        {author.position && <p class="profile-role">{author.position}</p>}
        {author.bioSummary && <div class="profile-summary" set:html={renderLexical(author.bioSummary)} />}
        {socialLinks.length ? <nav class="profile-contacts" aria-label={copy.contact}>{socialLinks.map((link) => <a href={link.url} aria-label={link.service}><i class={`ph ${iconByService[link.service] || 'ph-link'}`}></i></a>)}</nav> : null}
      </div>
      <aside class="profile-log" aria-label={copy.journal}><i class="ph ph-compass-rose"></i><span>{copy.journal}</span><b>46.1603° N</b><b>1.1511° W</b></aside>
    </header>
    {author.bio && <section class="profile-body"><div class="section-label"><span></span><p>{copy.bio}</p></div><div class="profile-prose" set:html={renderLexical(author.bio)} /></section>}
    {relatedPosts.length ? <section class="author-posts"><header><p>Navi.training</p><h2>{copy.articles}</h2></header><div class="post-grid">{relatedPosts.map((post) => <article><a href={post.route}>{post.image?.url && <img src={post.image.sizes?.card?.url || post.image.url} alt={post.imageAlt || post.name} loading="lazy" />}<div><h3>{post.name}</h3>{post.summary && <p>{post.summary}</p>}<span>{copy.read}<i class="ph ph-arrow-right"></i></span></div></a></article>)}</div></section> : null}
  </article>
</BaseLayout>
<style>
  .profile{max-width:1180px;margin:0 auto;padding:18px 0 82px;color:#073746}.profile-back{display:inline-flex;align-items:center;gap:9px;margin:0 0 28px;color:#526b73;font-weight:700;text-decoration:none}.profile-hero{position:relative;display:grid;grid-template-columns:minmax(300px,440px) minmax(320px,1fr);min-height:610px;background:#073746;color:#fff}.profile-photo{position:relative;margin:0;min-height:610px;overflow:hidden;background:#b7cdd1}.profile-photo img{width:100%;height:100%;object-fit:cover}.profile-photo>.ph{position:absolute;inset:50% auto auto 50%;font-size:9rem;transform:translate(-50%,-50%);color:#6f969f}.profile-photo span{position:absolute;right:-1px;bottom:0;width:72%;height:7px;background:#d97706}.profile-intro{align-self:center;padding:70px clamp(34px,7vw,92px)}.profile-eyebrow{margin:0 0 24px;color:#f5ae55;font:700 .76rem/1.2 Arial,sans-serif;letter-spacing:.15em;text-transform:uppercase}.profile h1{max-width:8ch;margin:0;font:400 clamp(3.4rem,7vw,6.5rem)/.93 'Tenor Sans',sans-serif;letter-spacing:-.045em}.profile-role{max-width:430px;margin:26px 0 0;color:#f5ae55;font-size:1rem;font-weight:700;line-height:1.5;text-transform:uppercase;letter-spacing:.08em}.profile-summary{max-width:560px;margin-top:28px;color:#d9e7e9;font-size:1.12rem;line-height:1.72}.profile-summary :global(p){margin:0}.profile-contacts{display:flex;gap:10px;margin-top:34px}.profile-contacts a{display:grid;width:42px;height:42px;place-items:center;border:1px solid rgba(255,255,255,.28);color:#fff;text-decoration:none;transition:background .18s,color .18s}.profile-contacts a:hover{background:#f5ae55;color:#073746}.profile-log{position:absolute;right:22px;bottom:20px;display:grid;grid-template-columns:auto auto;gap:5px 13px;color:#93b1b7;font:700 .65rem/1.2 Arial,sans-serif;letter-spacing:.1em;text-transform:uppercase}.profile-log i{grid-row:1/4;align-self:center;color:#f5ae55;font-size:2rem}.profile-log span{color:#fff}.profile-body{display:grid;grid-template-columns:220px minmax(0,720px);gap:70px;padding:86px clamp(10px,6vw,80px)}.section-label{display:flex;align-items:flex-start;gap:12px}.section-label span{width:42px;height:2px;margin-top:9px;background:#d97706}.section-label p{margin:0;color:#a55200;font:700 .72rem/1.4 Arial,sans-serif;letter-spacing:.14em;text-transform:uppercase}.profile-prose{font-size:1.08rem;line-height:1.75}.profile-prose :global(h2){margin:2.1em 0 .65em;font:400 clamp(1.8rem,4vw,2.7rem)/1.15 'Tenor Sans',sans-serif}.profile-prose :global(h2:first-child){margin-top:0}.profile-prose :global(p){margin:0 0 1.25em}.profile-prose :global(ul){margin:1.2em 0;padding:0;list-style:none}.profile-prose :global(li){position:relative;margin:.75em 0;padding-left:26px}.profile-prose :global(li)::before{position:absolute;left:0;top:.62em;width:9px;height:2px;content:'';background:#d97706}.profile-prose :global(a){color:#9b4e00;text-underline-offset:3px}.author-posts{padding:74px clamp(10px,5vw,54px);background:#edf4f4}.author-posts>header p{margin:0;color:#a55200;font:700 .72rem/1.3 Arial,sans-serif;letter-spacing:.14em;text-transform:uppercase}.author-posts>header h2{margin:9px 0 34px;font:400 clamp(2.4rem,5vw,4.4rem)/1 'Tenor Sans',sans-serif}.post-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.post-grid article{background:#fff;border:1px solid #d4e0e2}.post-grid a{display:flex;height:100%;flex-direction:column;color:inherit;text-decoration:none}.post-grid img{width:100%;aspect-ratio:16/9;object-fit:cover}.post-grid article div{display:flex;flex:1;flex-direction:column;padding:23px}.post-grid h3{margin:0;font:400 1.45rem/1.18 'Tenor Sans',sans-serif}.post-grid p{color:#597078;line-height:1.55}.post-grid span{display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:18px;border-top:1px solid #d8e3e5;font-weight:700}@media(max-width:820px){.profile-hero{grid-template-columns:1fr}.profile-photo{min-height:520px}.profile-intro{padding:52px 32px 96px}.profile-log{left:32px;right:auto}.profile-body{grid-template-columns:1fr;gap:30px}.post-grid{grid-template-columns:1fr 1fr}}@media(max-width:540px){.profile-photo{min-height:420px}.profile h1{font-size:3.25rem}.profile-body{padding:58px 8px}.post-grid{grid-template-columns:1fr}}
</style>
