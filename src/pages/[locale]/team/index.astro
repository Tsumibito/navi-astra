---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import payloadContent from '../../../data/payload-content.json';

export function getStaticPaths() {
  return ['ru', 'ua', 'en'].map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const authors = (payloadContent.entries || [])
  .filter((entry) => entry.kind === 'author' && entry.locale === dataLocale)
  .sort((a, b) => (a.order || 0) - (b.order || 0) || a.name.localeCompare(b.name));
const copy = {
  ru: { eyebrow: 'Команда Navi.training', title: 'Люди, которые открывают море', intro: 'Практикующие шкиперы и инструкторы. Мы обучаем управлению яхтой, проводим морскую практику и делимся опытом в бортовом журнале Navi.training.', open: 'Опыт и статьи', empty: 'Профили команды готовятся к публикации.' },
  ua: { eyebrow: 'Команда Navi.training', title: 'Люди, які відкривають море', intro: 'Практикуючі шкіпери та інструктори. Ми навчаємо керувати яхтою, проводимо морську практику й ділимося досвідом у бортовому журналі Navi.training.', open: 'Досвід і статті', empty: 'Профілі команди готуються до публікації.' },
  en: { eyebrow: 'The Navi.training team', title: 'The people who open up the sea', intro: 'Working skippers and instructors. We teach yacht handling, lead sea practice and share hard-won experience in the Navi.training logbook.', open: 'Experience and articles', empty: 'Team profiles are being prepared.' },
}[locale];
const description = copy.intro;
---
<BaseLayout title={`${copy.title} — Navi.training`} description={description} locale={locale} canonical={`https://navi.training/${locale}/team/`} languageHrefs={{ ru: '/ru/team/', ua: '/ua/team/', en: '/en/team/' }}>
  <section class="team-page">
    <header class="team-hero">
      <div class="team-hero__copy">
        <p class="team-eyebrow">{copy.eyebrow}</p>
        <h1>{copy.title}</h1>
        <p class="team-intro">{copy.intro}</p>
      </div>
    </header>
    {authors.length ? (
      <div class="team-grid">
        {authors.map((author) => {
          const photo = author.image?.sizes?.card?.url || author.image?.url;
          return <article class="crew-card">
            <a href={author.route} aria-label={`${copy.open}: ${author.name}`}>
              <figure>{photo ? <img src={photo} alt={author.image?.alt || author.name} loading="eager" /> : <i class="ph ph-user-circle" aria-hidden="true"></i>}</figure>
              <div class="crew-card__body">
                <p>{author.position || copy.eyebrow}</p>
                <h2>{author.name}</h2>
                {author.summary && <div class="crew-card__summary">{author.summary}</div>}
                <span>{copy.open}<i class="ph ph-arrow-up-right" aria-hidden="true"></i></span>
              </div>
            </a>
          </article>;
        })}
      </div>
    ) : <p class="empty">{copy.empty}</p>}
  </section>
</BaseLayout>
<style>
  .team-page{color:#073746}.team-hero{box-sizing:border-box;position:relative;width:100vw;min-height:600px;margin-left:calc(50% - 50vw);display:grid;place-items:center;padding:110px 24px;background:linear-gradient(rgba(5,37,48,.54),rgba(5,37,48,.78)),url('/cgi/asset/65f895a245162e324f6c32a4_im_head_2_Dp2AJPQEXOEYLvCklmCON.jpg') center/cover;color:#fff}.team-hero__copy{box-sizing:border-box;width:min(920px,100%);padding:clamp(38px,7vw,82px);border-radius:28px;background:rgba(255,255,255,.95);color:#073746;box-shadow:0 28px 80px rgba(0,28,38,.28)}.team-eyebrow{margin:0 0 20px;color:#a55200;font:700 .78rem/1.2 Arial,sans-serif;letter-spacing:.14em;text-transform:uppercase}.team-hero h1{max-width:12ch;margin:0;font:400 clamp(3.2rem,8vw,6.8rem)/.94 'Tenor Sans',sans-serif;letter-spacing:-.04em}.team-intro{max-width:670px;margin:30px 0 0;color:#425e67;font-size:1.16rem;line-height:1.7}.team-grid{box-sizing:border-box;width:min(1040px,calc(100% - 40px));margin:-58px auto 100px;position:relative;z-index:2;display:grid;gap:24px}.crew-card{overflow:hidden;border-radius:24px;background:#fff;box-shadow:0 18px 55px rgba(7,55,70,.18)}.crew-card>a{box-sizing:border-box;display:grid;grid-template-columns:220px minmax(0,1fr);align-items:center;min-height:300px;padding:38px;color:inherit;text-decoration:none}.crew-card figure{width:180px;height:180px;margin:0;overflow:hidden;border:7px solid #fff;border-radius:50%;background:#dce9eb;box-shadow:0 12px 32px rgba(7,55,70,.2)}.crew-card img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}.crew-card figure>.ph{display:grid;height:100%;place-items:center;color:#86a5ad;font-size:7rem}.crew-card__body{padding:4px 0}.crew-card__body>p{margin:0 0 12px;color:#a55200;font:700 .74rem/1.5 Arial,sans-serif;letter-spacing:.09em;text-transform:uppercase}.crew-card h2{margin:0;font:400 clamp(2.2rem,5vw,4rem)/1 'Tenor Sans',sans-serif}.crew-card__summary{max-width:58ch;margin:20px 0;color:#536970;font-size:1.05rem;line-height:1.65}.crew-card__body>span{display:inline-flex;align-items:center;gap:12px;margin-top:18px;color:#8e4800;font-weight:700}.crew-card:hover img{transform:scale(1.04)}.empty{width:min(920px,calc(100% - 40px));margin:40px auto 90px;padding:36px;background:#edf5f6}@media(max-width:700px){.team-hero{min-height:530px;padding:84px 14px 100px}.team-hero__copy{padding:38px 26px;border-radius:20px}.team-grid{margin-top:-68px}.crew-card>a{grid-template-columns:1fr;padding:30px}.crew-card figure{width:140px;height:140px;margin-bottom:26px}.team-hero h1{font-size:clamp(3rem,15vw,4.8rem)}}@media(prefers-reduced-motion:reduce){.crew-card img{transition:none}}
</style>
