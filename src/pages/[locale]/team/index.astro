---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import payloadContent from '../../../data/payload-content.json';

export function getStaticPaths() {
  return ['ru', 'ua', 'en'].map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale || 'ru';
const dataLocale = locale === 'ua' ? 'uk' : locale;
const authors = (payloadContent.entries || [])
  .filter((entry) => entry.kind === 'author' && entry.locale === dataLocale)
  .sort((a, b) => (a.order || 0) - (b.order || 0) || a.name.localeCompare(b.name));
const authorPostIds = new Set(authors.flatMap((author) => author.postIds || []).map(String));
const posts = (payloadContent.entries || [])
  .filter((entry) => entry.kind === 'post' && entry.locale === dataLocale && authorPostIds.has(String(entry.id)))
  .sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime())
  .slice(0, 3);
const copy = {
  ru: {
    eyebrow: 'Команда Navi.training', title: 'Люди, которые открывают море',
    intro: 'Navi.training создают практикующие шкиперы и инструкторы. Мы учим управлять яхтой, отвечать за экипаж и принимать решения там, где теория встречается с настоящим морем.',
    who: 'Кто стоит за Navi.training', whoText: 'Наша школа выросла из реальных переходов, учебных походов и многолетней работы с экипажами. Поэтому каждый курс, маршрут и материал в журнале опирается на опыт, который можно проверить на воде.',
    principles: [['Практика прежде всего', 'Разбираем не абстрактные ситуации, а реальные задачи шкипера: погоду, навигацию, манёвры и взаимодействие с экипажем.'], ['Ответственность за людей', 'Хороший капитан не демонстрирует власть — он создаёт понятный порядок, спокойствие и безопасность на борту.'], ['Знания остаются с вами', 'Учебные материалы и статьи помогают возвращаться к сложным темам после курса и готовиться к новым маршрутам.']],
    open: 'Опыт и статьи', empty: 'Профили команды готовятся к публикации.', journal: 'Бортовой журнал команды', journalText: 'Наблюдения, практические разборы и морские истории от инструкторов Navi.training.', read: 'Читать статью', allPosts: 'Все статьи',
  },
  ua: {
    eyebrow: 'Команда Navi.training', title: 'Люди, які відкривають море',
    intro: 'Navi.training створюють практикуючі шкіпери та інструктори. Ми навчаємо керувати яхтою, відповідати за екіпаж і приймати рішення там, де теорія зустрічається зі справжнім морем.',
    who: 'Хто стоїть за Navi.training', whoText: 'Наша школа виросла з реальних переходів, навчальних походів і багаторічної роботи з екіпажами. Тому кожен курс, маршрут і матеріал у журналі спирається на досвід, який можна перевірити на воді.',
    principles: [['Практика передусім', 'Розбираємо не абстрактні ситуації, а реальні завдання шкіпера: погоду, навігацію, маневри та взаємодію з екіпажем.'], ['Відповідальність за людей', 'Хороший капітан не демонструє владу — він створює зрозумілий порядок, спокій і безпеку на борту.'], ['Знання залишаються з вами', 'Навчальні матеріали та статті допомагають повертатися до складних тем після курсу й готуватися до нових маршрутів.']],
    open: 'Досвід і статті', empty: 'Профілі команди готуються до публікації.', journal: 'Бортовий журнал команди', journalText: 'Спостереження, практичні розбори й морські історії від інструкторів Navi.training.', read: 'Читати статтю', allPosts: 'Усі статті',
  },
  en: {
    eyebrow: 'The Navi.training team', title: 'The people who open up the sea',
    intro: 'Navi.training is built by working skippers and instructors. We teach people to handle a yacht, take responsibility for a crew and make sound decisions where theory meets the real sea.',
    who: 'Who stands behind Navi.training', whoText: 'Our school grew out of real passages, training voyages and years of working with crews. Every course, route and journal article is therefore grounded in experience that can be tested on the water.',
    principles: [['Practice comes first', 'We work through real skipper problems: weather, navigation, manoeuvres and clear cooperation with the crew.'], ['Responsibility for people', 'A good captain does not perform authority. They create clarity, calm and safety on board.'], ['Knowledge stays with you', 'Training materials and articles let you revisit difficult subjects after a course and prepare for the next voyage.']],
    open: 'Experience and articles', empty: 'Team profiles are being prepared.', journal: 'The team logbook', journalText: 'Observations, practical seamanship and stories from Navi.training instructors.', read: 'Read article', allPosts: 'All articles',
  },
}[locale as 'ru' | 'ua' | 'en'] ?? { eyebrow: '', title: '', intro: '', who: '', whoText: '', principles: [] as [string, string][], open: '', empty: '', journal: '', journalText: '', read: '', allPosts: '' };
---
<BaseLayout fullBleed title={`${copy.title} — Navi.training`} description={copy.intro} locale={locale} canonical={`https://navi.training/${locale}/team/`} languageHrefs={{ ru: '/ru/team/', ua: '/ua/team/', en: '/en/team/' }}>
  <article class="team-page">
    <header class="team-hero"><div class="team-hero__inner"><p class="section-kicker">{copy.eyebrow}</p><h1>{copy.title}</h1><p>{copy.intro}</p></div></header>

    <section class="team-section team-intro"><div class="section-inner intro-grid"><header><p class="section-kicker">Navi.training</p><h2>{copy.who}</h2><p>{copy.whoText}</p></header><div class="principles">{copy.principles.map(([title, text], index) => <article><span>0{index + 1}</span><h3>{title}</h3><p>{text}</p></article>)}</div></div></section>

    <section class="team-section team-members"><div class="section-inner">
      {authors.length ? <div class="team-grid">{authors.map((author: any) => { const photo = (author.image as any)?.sizes?.card?.url || (author.image as any)?.url; return <article class="crew-card"><a href={author.route} aria-label={`${copy.open}: ${author.name}`}><figure>{photo ? <img src={photo} alt={(author.image as any)?.alt || author.name} loading="eager" /> : <i class="ph ph-user-circle" aria-hidden="true"></i>}</figure><div class="crew-card__body"><p>{author.position || copy.eyebrow}</p><h2>{author.name}</h2>{author.summary && <div class="crew-card__summary">{author.summary}</div>}<span>{copy.open}<i class="ph ph-arrow-up-right" aria-hidden="true"></i></span></div></a></article>; })}</div> : <p class="empty">{copy.empty}</p>}
    </div></section>

    {posts.length ? <section class="team-section team-journal"><div class="section-inner"><header class="journal-heading"><div><p class="section-kicker">Navi.training</p><h2>{copy.journal}</h2></div><p>{copy.journalText}</p></header><div class="post-grid">{posts.map((post: any) => <article class="post-card"><a href={post.route}>{post.image?.url && <img src={post.image.sizes?.card?.url || post.image.url} alt={post.imageAlt || post.name} loading="lazy" />}<div><h3>{post.name}</h3>{post.summary && <p>{post.summary}</p>}<span>{copy.read}<i class="ph ph-arrow-right" aria-hidden="true"></i></span></div></a></article>)}</div><a class="all-posts" href={`/${locale}/blog/`}>{copy.allPosts}<i class="ph ph-arrow-up-right" aria-hidden="true"></i></a></div></section> : null}
  </article>
</BaseLayout>
<style>
  .team-page{overflow:hidden;color:#073746;background:#dce9e9}.section-inner,.team-hero__inner{width:min(1180px,100%);margin:auto}.section-kicker{margin:0 0 14px;color:#d97706;font:700 12px/1.35 Arial,sans-serif;letter-spacing:.14em;text-transform:uppercase}.team-hero{min-height:660px;padding:118px 24px 160px;box-sizing:border-box;color:#fff;background:linear-gradient(90deg,rgba(4,38,49,.84),rgba(4,38,49,.4)),url('/cgi/asset/65f895a245162e324f6c32a4_im_head_2_Dp2AJPQEXOEYLvCklmCON.jpg') center/cover}.team-hero h1{max-width:12ch;margin:0;font:400 clamp(60px,8vw,108px)/.9 'Tenor Sans',sans-serif;letter-spacing:-.045em}.team-hero__inner>p:last-child{max-width:730px;margin:32px 0 0;color:#e2edef;font-size:20px;line-height:1.7}.team-section{position:relative;box-sizing:border-box;padding:clamp(68px,8vw,112px) 24px;border-radius:60px 60px 0 0;box-shadow:0 -7px 20px rgba(20,61,70,.18)}.team-intro{margin-top:-70px;background:#fff}.intro-grid{display:grid;grid-template-columns:minmax(280px,.75fr) minmax(0,1.25fr);gap:clamp(50px,8vw,110px)}.intro-grid>header h2,.journal-heading h2{margin:0;font:400 clamp(42px,5.5vw,72px)/1 'Tenor Sans',sans-serif;letter-spacing:-.03em}.intro-grid>header>p:last-child{margin:28px 0 0;color:#526a72;font-size:18px;line-height:1.72}.principles{display:grid;gap:14px}.principles article{display:grid;grid-template-columns:54px minmax(0,1fr);column-gap:20px;padding:24px;border:1px solid rgba(7,55,70,.15);border-radius:18px;background:#f8fbfa}.principles span{grid-row:1/3;color:#d97706;font:400 30px/1 'Tenor Sans',sans-serif}.principles h3{margin:0;font:400 25px/1.15 'Tenor Sans',sans-serif}.principles p{margin:10px 0 0;color:#5a7077;line-height:1.6}.team-members{margin-top:-36px;background:#e9f2f1}.team-grid{display:grid;gap:24px}.crew-card{overflow:hidden;border-radius:24px;background:#fff;box-shadow:0 18px 55px rgba(7,55,70,.15)}.crew-card>a{box-sizing:border-box;display:grid;grid-template-columns:260px minmax(0,1fr);align-items:center;min-height:330px;padding:38px;color:inherit;text-decoration:none}.crew-card figure{width:210px;height:210px;margin:0;overflow:hidden;border:7px solid #fff;border-radius:50%;background:#dce9eb;box-shadow:0 12px 32px rgba(7,55,70,.2)}.crew-card img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}.crew-card figure>.ph{display:grid;height:100%;place-items:center;color:#86a5ad;font-size:7rem}.crew-card__body>p{margin:0 0 12px;color:#a55200;font:700 12px/1.5 Arial,sans-serif;letter-spacing:.09em;text-transform:uppercase}.crew-card h2{margin:0;font:400 clamp(40px,5vw,66px)/1 'Tenor Sans',sans-serif}.crew-card__summary{max-width:650px;margin:20px 0;color:#536970;font-size:17px;line-height:1.65}.crew-card__body>span{display:inline-flex;align-items:center;gap:12px;margin-top:18px;color:#8e4800;font-weight:700}.crew-card:hover img{transform:scale(1.04)}.empty{padding:36px;border-radius:18px;background:#fff}.team-journal{margin-top:-36px;background:#f8fbfa}.journal-heading{display:grid;grid-template-columns:1fr minmax(260px,.62fr);gap:50px;align-items:end;margin-bottom:42px}.journal-heading>p{margin:0;color:#526a72;font-size:17px;line-height:1.65}.post-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.post-card{overflow:hidden;border:1px solid rgba(7,55,70,.14);border-radius:18px;background:#fff;box-shadow:0 12px 30px rgba(7,55,70,.07)}.post-card a{display:flex;height:100%;flex-direction:column;color:inherit;text-decoration:none}.post-card img{width:100%;aspect-ratio:16/9;object-fit:cover}.post-card div{display:flex;flex:1;flex-direction:column;padding:23px}.post-card h3{margin:0;font:400 24px/1.17 'Tenor Sans',sans-serif}.post-card p{display:-webkit-box;overflow:hidden;margin:16px 0;color:#5a7077;line-height:1.55;-webkit-box-orient:vertical;-webkit-line-clamp:4}.post-card span{display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:17px;border-top:1px solid #dce5e7;color:#914900;font-weight:700}.all-posts{display:inline-flex;align-items:center;gap:10px;margin-top:36px;padding:15px 20px;border-radius:9px;background:#f5a442;color:#073746;font-weight:700;text-decoration:none}@media(max-width:850px){.intro-grid,.journal-heading{grid-template-columns:1fr}.crew-card>a{grid-template-columns:190px 1fr}.crew-card figure{width:155px;height:155px}.post-grid{grid-template-columns:1fr 1fr}}@media(max-width:600px){.team-hero{min-height:610px;padding:90px 18px 120px}.team-hero h1{font-size:clamp(52px,17vw,76px)}.team-section{padding:58px 18px;border-radius:36px 36px 0 0}.team-intro{margin-top:-38px}.team-members,.team-journal{margin-top:-20px}.crew-card>a{grid-template-columns:1fr;padding:30px}.crew-card figure{margin-bottom:26px}.post-grid{grid-template-columns:1fr}}
</style>
