import ServiceLayout from '../../layouts/ServiceLayout.astro'; import ServiceLeadForm from '../../components/ServiceLeadForm.astro';
const schema={'@context':'https://schema.org','@type':'Service',name:'Yacht delivery from France',description:'Owner-assisted or fully crewed yacht delivery from the French Atlantic coast.',provider:{'@type':'Organization',name:'Navi.training',url:'https://navi.training'},areaServed:['France','Europe','Atlantic Ocean','Mediterranean Sea'],serviceType:'Yacht delivery and owner-assisted passage',availableLanguage:['ru','uk','en'],url:'https://navi.training/en/yacht-delivery'};
---
<ServiceLayout title="Yacht delivery from France — owner-assisted or turnkey | Navi" description="Professional sailing yacht delivery from the French Atlantic coast across Biscay, Europe and the Atlantic." image="/services/yacht-delivery-hero.webp" locale="en" slug="yacht-delivery" schema={schema}>
<section class="service-hero"><img src="/services/yacht-delivery-hero.webp" alt="Sailing yacht on a Bay of Biscay passage" fetchpriority="high"/><div class="service-shell hero-content"><p class="eyebrow">Yacht delivery · French Atlantic</p><h1>Your yacht.<br/>The right shore.</h1><p class="lead">I can skipper the passage alongside you, or assemble a professional crew and deliver the yacht turnkey from La Rochelle, Les Sables-d’Olonne, Cherbourg and other ports.</p><div class="hero-actions"><button class="btn-primary" data-open-service-form>Discuss the passage <span>↗</span></button><a class="btn-secondary" href="#formats">Choose a format</a></div><div class="route-line"><span>Bay of Biscay</span><span>Mediterranean</span><span>Atlantic</span></div></div></section>
<section class="service-section" id="formats"><div class="service-shell"><div class="section-head"><p class="eyebrow">Two formats</p><div><h2>Join the passage — or meet your yacht at her destination</h2></div></div><div class="choice-grid"><article class="choice-card"><span class="number">01</span><h3>Owner-assisted passage</h3><p>An experienced skipper leads a safe passage while helping you learn your own yacht in real conditions.</p><ul><li>Route and weather-window planning</li><li>Watchkeeping and crew organisation</li><li>Sails, manoeuvres and onboard systems</li><li>Biscay and, when required, the Atlantic</li></ul></article><article class="choice-card"><span class="number">02</span><h3>Turnkey delivery</h3><p>I select the crew, prepare the yacht, manage the passage and hand her over at the agreed destination.</p><ul><li>Professional skipper and crew</li><li>Pre-departure readiness check</li><li>Passage updates and reporting</li><li>Documented final handover</li></ul></article></div></div></section>
<section class="dark-section service-section"><div class="service-shell"><div class="section-head"><p class="eyebrow">The process</p><p>Departure is governed by yacht readiness, weather and safety — never by the calendar at any cost.</p></div><div class="process"><article><b>01 · Brief</b><h3>Yacht and route</h3><p>Model, condition, insurance, ports and preferred dates.</p></article><article><b>02 · Before sailing</b><h3>Readiness</h3><p>Critical systems, safety equipment and action list.</p></article><article><b>03 · At sea</b><h3>Passage</h3><p>Weather decisions, watches, systems monitoring and updates.</p></article><article><b>04 · Arrival</b><h3>Handover</h3><p>Secure berthing, condition record and owner report.</p></article></div></div></section>
<section class="image-story"><img src="/services/yacht-delivery-owner-assisted.webp" alt="Skipper and owner reviewing the passage plan" loading="lazy"/><div class="story-copy"><p class="eyebrow">Owner-assisted passage</p><h2>More than arriving. Learn your yacht underway.</h2><p>A first serious passage reveals how the yacht behaves, how her systems work and how life aboard should be organised.</p><blockquote>My role is not to take the helm away, but to provide calm support until experience catches up.</blockquote></div></section>
<section class="service-section"><div class="service-shell"><div class="section-head"><p class="eyebrow">Questions</p><div><h2>Before the passage</h2></div></div><div class="faq"><details><summary>When can the departure date be confirmed?</summary><p>We agree a working window first. Final departure depends on the forecast and yacht readiness.</p></details><details><summary>Can family or friends join?</summary><p>Yes, when the yacht, route and participants’ experience allow safe watchkeeping.</p></details><details><summary>What do you need for an estimate?</summary><p>Yacht model and year, ports, preferred dates, technical condition, equipment and chosen format.</p></details></div></div></section>
<section class="service-cta"><div class="service-shell service-cta__inner"><div><p class="eyebrow">The next waypoint</p><h2>Every sound passage starts ashore</h2><p>Tell me about the yacht, route and timing. I will propose a realistic format.</p></div><button class="btn-primary" data-open-service-form>Discuss the delivery <span>↗</span></button></div></section><ServiceLeadForm service="yacht-delivery" locale="en" title="Let’s chart the first route ashore" intro="A few practical details will make our first conversation useful." button="Discuss the delivery"/>
</ServiceLayout>
