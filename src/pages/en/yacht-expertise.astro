import ServiceLayout from '../../layouts/ServiceLayout.astro'; import ServiceLeadForm from '../../components/ServiceLeadForm.astro';
const schema={'@context':'https://schema.org','@type':'Service',name:'Independent yacht purchase advisory',description:'Independent guidance for yacht selection, specification, handover and commissioning.',provider:{'@type':'Organization',name:'Navi.training',url:'https://navi.training'},areaServed:['France','Mediterranean Sea'],serviceType:'Yacht purchase advisory and commissioning support',availableLanguage:['ru','uk','en'],url:'https://navi.training/en/yacht-expertise'};
---
<ServiceLayout title="Independent yacht purchase advisory and commissioning | Navi" description="Independent owner-side support for yacht selection, specification, handover, commissioning and first offshore passage." image="/services/yacht-expertise-hero.webp" locale="en" slug="yacht-expertise" schema={schema}>
<section class="service-hero"><img src="/services/yacht-expertise-hero.webp" alt="Advisor and owner checking a new yacht's systems" fetchpriority="high"/><div class="service-shell hero-content"><p class="eyebrow">Owner’s side · Yacht advisory</p><h1>A yacht<br/>you understand.</h1><p class="lead">Independent support from model and options selection through handover, commissioning and your first serious passage.</p><div class="hero-actions"><button class="btn-primary" data-open-service-form>Discuss your yacht <span>↗</span></button><a class="btn-secondary" href="#scope">What I check</a></div><div class="route-line"><span>French Atlantic coast</span><span>Mediterranean</span><span>Travel support</span></div></div></section>
<section class="service-section"><div class="service-shell"><div class="section-head"><p class="eyebrow">Not a broker. Not a dealer.</p><div><h2>On your side — from yacht selection to the first passage</h2></div></div><div class="choice-grid"><article class="choice-card"><span class="number">Before</span><h3>Yacht and specification</h3><p>We begin with your actual cruising plans, crew, autonomy and appetite for maintenance.</p><ul><li>Models compared against your use case</li><li>Popular YouTube advice tested critically</li><li>Useful versus pushed options</li><li>Preparation before the yard contract</li></ul></article><article class="choice-card"><span class="number">After</span><h3>Handover and commissioning</h3><p>We check what was supplied and installed, test systems and turn a new yacht into a dependable working boat.</p><ul><li>Specification and workmanship checks</li><li>Sea trials and snagging list</li><li>Equipment and spares organisation</li><li>Owner training aboard your yacht</li></ul></article></div><p class="note"><strong>This is not a technical survey.</strong> I represent the owner’s practical interests. When a formal condition report is required, we appoint an independent specialist surveyor.</p></div></section>
<section class="dark-section service-section" id="scope"><div class="service-shell"><div class="section-head"><p class="eyebrow">Complete cycle</p><p>From one independent consultation to several weeks alongside the owner after handover.</p></div><div class="process"><article><b>01 · Use case</b><h3>How you will sail</h3><p>Waters, crew, autonomy and long-term plans.</p></article><article><b>02 · Specification</b><h3>What you need</h3><p>Yard package, priorities and ownership costs.</p></article><article><b>03 · Handover</b><h3>What was delivered</h3><p>Equipment, installation, systems and snags.</p></article><article><b>04 · Familiarisation</b><h3>How it all works</h3><p>Manoeuvres, routines and emergency scenarios.</p></article></div></div></section>
<section class="image-story"><img src="/services/yacht-expertise-preparation.webp" alt="Preparing a new yacht's equipment for sea" loading="lazy"/><div class="story-copy"><p class="eyebrow">Commissioning for real life</p><h2>The yard delivers a yacht. We prepare her for sea.</h2><p>Equipment must be checked, organised and available when needed. Critical systems should make sense to the person who owns the boat.</p><blockquote>A good handover ends not with a signature, but with the confidence to leave the marina independently.</blockquote></div></section>
<section class="service-section"><div class="service-shell"><div class="section-head"><p class="eyebrow">Questions</p><div><h2>Before signing the contract</h2></div></div><div class="faq"><details><summary>When should I involve an advisor?</summary><p>Ideally while choosing the yacht, before signing with the yard. This avoids mistakes in the fundamental concept and expensive options driven by popular online opinions. A centre cockpit or twin keel may be interesting, for example, but not necessarily sensible for your own Mediterranean plans.</p></details><details><summary>When is a surveyor required?</summary><p>When the purchase, insurer or a technical concern requires a formal condition report and specialist inspection.</p></details><details><summary>Can support continue after handover?</summary><p>Yes, until you are confident with the systems, harbour manoeuvres and normal onboard routines.</p></details></div></div></section>
<section class="service-cta"><div class="service-shell service-cta__inner"><div><p class="eyebrow">An independent view</p><h2>Start with your plans, not an options catalogue</h2><p>Tell me which yacht you are considering and where you are in the purchase process.</p></div><button class="btn-primary" data-open-service-form>Request a consultation <span>↗</span></button></div></section><ServiceLeadForm service="yacht-expertise" locale="en" title="Let’s discuss your yacht" intro="The model, purchase stage and intended cruising area will make our first conversation useful." button="Request a consultation"/>
</ServiceLayout>
