---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Navi • Astro 5 + Tailwind">
  <section class="py-10">
    <h1 class="text-3xl font-bold">Navi Frontend</h1>
    <p class="mt-3 text-slate-600">Astro 5 + Tailwind, готово к деплою на Cloudflare Pages.</p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <a class="block rounded-lg border border-slate-200 bg-white p-4 shadow-sm hover:shadow" href="https://docs.astro.build" target="_blank">Документация Astro</a>
      <a class="block rounded-lg border border-slate-200 bg-white p-4 shadow-sm hover:shadow" href="https://tailwindcss.com/docs" target="_blank">Документация Tailwind</a>
    </div>
  </section>
</BaseLayout>
