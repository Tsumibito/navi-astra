---
import BaseLayout from '~/layouts/BaseLayout.astro';
import RelatedPosts from '~/components/RelatedPosts.astro';
import ServiceLeadForm from '~/components/ServiceLeadForm.astro';
import payloadContent from '~/data/payload-content.json';

const locale = 'ru';
const posts = (payloadContent.entries || [])
  .filter((e: any) => e.kind === 'post' && e.locale === 'ru')
  .sort((a: any, b: any) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime())
  .slice(0, 3);
const structuredData = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Navi.training', url: 'https://navi.training' };

const faqs = [
  { q: 'Где вы находитесь?', a: 'Наш главный офис находится во Франции, в городе Ла-Рошель. Наш адрес вы найдете в футере сайта. Также у нас есть тренировочные базы в Турции, Черногории и Испании, откуда обычно выходят наши группы морской практики.' },
  { q: 'Где можно узнать больше о яхтинге?', a: 'На сайте Navi.training есть отличный блог, где публикуются статьи о яхтинге, содержащие новости, лайфхаки и учебные материалы.' },
  { q: 'Какие виды оплаты вы принимаете и в какой валюте?', a: 'MON NAVI SARL — французская компания, расположенная в городе Lagord в департаменте Charente-Maritime на Атлантическом побережье Франции. Обычно мы принимаем SEPA-платежи в евро на наш IBAN счет либо оплаты картой через Stripe или PayPal.' },
  { q: 'Как можно попасть к вам в команду?', a: 'Да, Navi.training принимает в свою команду талантливых инструкторов и технических специалистов. Отправьте ваше резюме на alex@navi.training.' },
];

const services = [
  { title: 'Яхтенные путешествия', img: '/cgi/asset/d1_fbhg7RFOSlLE54k2Bn_10.jpg', href: '/ru/tags/sailing-routes' },
  { title: 'Чартерное агентство', img: '/cgi/asset/charter_CaMIqlIxXrgBOs_OGlx3c.jpg', href: '/ru/charter' },
  { title: 'Перегон яхт', img: '/cgi/asset/d3_f0m__GKS68QPwyf1hbhr_.jpg', href: '/ru/yacht-delivery' },
  { title: 'Яхтенная экспертиза', img: '/cgi/asset/d4_9OiH95C1QsgAeaZAHUIRu.jpg', href: '/ru/yacht-expertise' },
];
---
<BaseLayout locale={locale} title="Яхтенная компания Navi.training — центр развития яхтинга" description="Navi.training поможет вам осуществить мечту о море: научим управлять яхтой, организуем чартер, перегон и экспертизу." canonical="https://navi.training/" structuredData={structuredData} fullBleed={true}>
  <section class="home-hero" style="--home-hero-bg:url('/cgi/asset/65f895a245162e324f6c32a4_im_head_2_Dp2AJPQEXOEYLvCklmCON.jpg')">
    <div class="home-hero__inner">
      <p class="home-hero__eyebrow">ЦЕНТР РАЗВИТИЯ ЯХТИНГА</p>
      <h1>NAVI.TRAINING</h1>
      <p class="home-hero__lead">Обучение яхтингу, чартер, перегон, экспертиза.</p>
      <button class="home-btn home-btn--hero" data-open-service-form type="button">Подать заявку</button>
    </div>
  </section>

  <section class="home-mission">
    <div class="home-mission__inner">
      <div class="home-mission__top">
        <h2><em>Наша миссия:</em> Делаем яхтинг доступным, помогая каждому осуществить мечту о море.</h2>
        <div class="home-mission__desc">
          <p><strong>Navi.training</strong> — это ваш надежный партнер в непростом мире яхтинга. Мы поможем вам осуществить мечту о море, <strong>научим вас управлять практически любой яхтой</strong>, организуем незабываемый отдых под парусом, доставим вашу яхту в любую точку мира и <strong>поможем сделать правильный выбор при покупке судна</strong>.</p>
        </div>
      </div>
      <div class="home-mission__grid">
        <article>
          <img src="/cgi/asset/65f9b20c901f9928f7286d2a_online-learning_tt0JgWwNp4yadNtYoCYMj.png" alt="" loading="lazy" width="80" height="80" />
          <p><span class="home-accent">Создаем современные обучающие материалы</span> по яхтингу, чтобы упростить доступ к обучению яхтсменов и подарить вам уверенность на воде.</p>
        </article>
        <article>
          <img src="/cgi/asset/65f9b1ff4a7f117a3441b5ea_ship_nJ_S58ya0Ots2jtZLdcJY.png" alt="" loading="lazy" width="80" height="80" />
          <p><span class="home-accent">Делаем доступным незабываемый отдых под парусом</span>, помогая нашим клиентам арендовать яхту пв любом регионе мира, как со шкипером так и без.</p>
        </article>
        <article>
          <img src="/cgi/asset/65f9b1e971700faa5162aca0_certificate_78tZEYMTg4W8VumhYtEXH.png" alt="" loading="lazy" width="80" height="80" />
          <p><span class="home-accent">Развиваем яхтенное сообщество</span>, и делаем яхтинг ближе и понятнее для широкого круга людей всех возрастов и профессий.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="home-services">
    <img class="home-decor home-decor--left" src="/cgi/asset/65f8ad0d3d1953c8a85fc539_corv1_hrBlJIX0cvydO4TTwF1xt.svg" alt="" loading="lazy" />
    <img class="home-decor home-decor--right" src="/cgi/asset/65f8ad0d3d1953c8a85fc539_corv1_hrBlJIX0cvydO4TTwF1xt.svg" alt="" loading="lazy" />
    <div class="home-services__inner">
      <h2>Путешествия и яхтенный чартер</h2>
      <div class="home-services__grid">
        {services.map((s) => (
          <a href={s.href} class="home-service-card">
            <img src={s.img} alt={s.title} loading="lazy" />
            <span>{s.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-charter">
    <div class="home-charter__inner">
      <div class="home-charter__copy">
        <h2>Бронирование чартера с нашими капитанами</h2>
        <p>Мечтаете о незабываемом путешествии на яхте? Забронируйте чартер с нашими опытными капитанами уже сегодня!</p>
        <p>Почувствуйте ветер в волосах и свободу моря с нашими профессионалами на борту!</p>
        <a class="home-btn" href="/ru/charter">Хочу в чартер</a>
      </div>
      <figure class="home-charter__figure">
        <img src="/cgi/asset/65f964fdb1dce55364cb48c9_charter-im_p20PKdNK0KFgmmskgS7Ir.jpg" alt="Чартерная яхта" loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="home-put">
    <img class="home-decor home-decor--left" src="/cgi/asset/65f8ad0d3d1953c8a85fc539_corv1_hrBlJIX0cvydO4TTwF1xt.svg" alt="" loading="lazy" />
    <img class="home-decor home-decor--right" src="/cgi/asset/65f8ad0d3d1953c8a85fc539_corv1_hrBlJIX0cvydO4TTwF1xt.svg" alt="" loading="lazy" />
    <div class="home-put__inner">
      <h2>Ваша яхта, может работать у нас</h2>
      <p><strong>Ваша яхта — это возможность для всех!</strong></p>
      <p>‘Put your boat to work’ позволяет вам делиться своей морской страстью, сдавая ее в аренду, и окупать расходы на содержание вашей яхты или даже неплохо зарабатывать на ней.</p>
      <a class="home-btn home-btn--outline" href="/ru/charter">Условия сотрудничества</a>
    </div>
  </section>

  <section class="home-encyclo">
    <div class="home-encyclo__inner">
      <div class="home-encyclo__copy">
        <span class="home-eyebrow">Яхтенная энциклопедия</span>
        <h2>Море говорит на своём языке</h2>
        <p>Понятный справочник яхтенных терминов: от устройства судна и ветра до навигации и безопасности.</p>
        <a class="home-link" href="/ru/encyclopedia">Открыть энциклопедию <span>→</span></a>
        <div class="home-coords">46.1603° N<br />1.1511° W</div>
      </div>
    </div>
  </section>

  <section class="home-faq">
    <div class="home-faq__inner">
      <h2>FAQs</h2>
      <div class="home-faq__list">
        {faqs.map((f) => (
          <details>
            <summary>{f.q}<span aria-hidden="true">+</span></summary>
            <div class="home-faq__answer"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
      <div class="home-faq__cta">
        <h3>Остались еще вопросы?</h3>
        <p>Свяжитесь с нами, наши менеджеры будут рады вам помочь</p>
        <button class="home-btn" data-open-service-form type="button">Задать вопрос</button>
      </div>
    </div>
  </section>

  <RelatedPosts posts={posts} locale={locale} />

  <ServiceLeadForm locale={locale} service="general" title="Свяжитесь с нами" intro="Расскажите, чем мы можем помочь, и мы свяжемся с вами в ближайшее время." button="Отправить" />
</BaseLayout>

<style is:global>
  .home-hero{position:relative;display:grid;min-height:clamp(480px,75vh,800px);place-items:center;overflow:hidden;color:#fff;background:linear-gradient(180deg,rgba(7,55,70,.52) 0%,rgba(7,55,70,.72) 100%),var(--home-hero-bg) center/cover no-repeat #073746;text-align:center}
  .home-hero__inner{width:min(1180px,calc(100% - 40px));margin-inline:auto}
  .home-hero__eyebrow{margin:0 0 10px;font:400 clamp(18px,2.2vw,24px)/1.3 'Tenor Sans',sans-serif;letter-spacing:.12em;color:#e9f2f1}
  .home-hero h1{margin:0 0 14px;font:400 clamp(48px,8vw,110px)/0.95 'Tenor Sans',sans-serif;letter-spacing:-.02em;color:#fff}
  .home-hero__lead{max-width:620px;margin:0 auto 32px;font:italic 400 clamp(17px,1.8vw,22px)/1.55 'Tenor Sans',sans-serif;color:#e9f2f1}
  .home-btn{display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:0 32px;border:0;border-radius:5px;background:#ffb052;color:#fff;font:700 15px/1 Arial,sans-serif;text-decoration:none;cursor:pointer;transition:background .2s}
  .home-btn:hover{background:#e89a3a}
  .home-btn--hero{background:transparent;border:1px solid #ffb052;color:#ffb052}
  .home-btn--hero:hover{background:#ffb052;color:#fff}
  .home-btn--outline{background:transparent;color:#fff;border:1px solid #fff}
  .home-btn--outline:hover{background:rgba(255,255,255,.1)}

  .home-mission{width:100%;box-sizing:border-box;padding:clamp(56px,8vw,100px) 24px;color:#fff;background:linear-gradient(135deg,#073746 0%,#0d4c5d 60%,#0d4c5d 100%);border-radius:60px 60px 0 0;margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25))}
  .home-mission__inner{max-width:1180px;margin-inline:auto}
  .home-mission__top{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,.95fr);gap:clamp(32px,5vw,72px);align-items:start;margin-bottom:56px}
  .home-mission h2{margin:0;font:400 clamp(28px,3.8vw,48px)/1.15 'Tenor Sans',sans-serif;color:#fff}
  .home-mission h2 em{font-style:italic;color:#ffb052}
  .home-mission__desc{color:#e9f2f1;font-size:clamp(15px,1.4vw,17px);line-height:1.75}
  .home-mission__desc p{margin:0}
  .home-mission__desc strong{color:#fff}
  .home-mission__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:32px}
  .home-mission__grid article{display:grid;gap:14px;justify-items:center;text-align:center}
  .home-mission__grid img{width:80px;height:80px;object-fit:contain;filter:brightness(0) invert(1);opacity:.9}
  .home-mission__grid p{margin:0;font-size:15px;line-height:1.65;color:#e9f2f1}
  .home-accent{color:#ffb052}

  .home-services,.home-put{width:100%;box-sizing:border-box;padding:clamp(56px,8vw,100px) 24px;background:var(--ds-paper,#f7faf9);position:relative;overflow:hidden}
  .home-services{border-radius:60px 60px 0 0;margin-top:calc(-1 * var(--ds-section-overlap,60px));z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25))}
  .home-put{border-radius:60px 60px 0 0;margin-top:calc(-1 * var(--ds-section-overlap,60px));z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25));background:#fff}
  .home-services__inner,.home-put__inner{position:relative;z-index:2;max-width:1180px;margin-inline:auto}
  .home-services h2,.home-put h2{margin:0 0 32px;font:400 clamp(28px,3.8vw,48px)/1.1 'Tenor Sans',sans-serif;color:var(--ds-ink,#073746)}
  .home-services__grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:20px}
  .home-service-card{position:relative;display:block;aspect-ratio:3/4;border-radius:18px;overflow:hidden;text-decoration:none;box-shadow:var(--ds-shadow-card)}
  .home-service-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .home-service-card span{position:absolute;right:0;bottom:0;left:0;padding:64px 18px 18px;color:#fff;background:linear-gradient(transparent,rgba(7,55,70,.88));font:400 18px/1.25 'Tenor Sans',sans-serif}
  .home-decor{position:absolute;top:50%;width:160px;height:auto;opacity:.25;transform:translateY(-50%);pointer-events:none}
  .home-decor--left{left:-20px}
  .home-decor--right{right:-20px;transform:translateY(-50%) scaleX(-1)}
  .home-put p{max-width:840px;margin:0 0 18px;font-size:clamp(16px,1.5vw,19px);line-height:1.7;color:var(--ds-ink)}
  .home-put .home-btn--outline{color:var(--ds-ink);border-color:var(--ds-ink)}
  .home-put .home-btn--outline:hover{background:rgba(7,55,70,.06)}

  .home-charter{width:100%;box-sizing:border-box;padding:clamp(56px,8vw,100px) 24px;background:#fff;border-radius:60px 60px 0 0;margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25))}
  .home-charter__inner{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr);gap:clamp(32px,6vw,72px);align-items:center;max-width:1180px;margin-inline:auto}
  .home-charter__copy h2{margin:0 0 24px;font:400 clamp(28px,3.8vw,48px)/1.1 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .home-charter__copy p{margin:0 0 16px;font-size:clamp(16px,1.5vw,19px);line-height:1.7;color:#52656b}
  .home-charter__copy .home-btn{margin-top:10px}
  .home-charter__figure{margin:0}
  .home-charter__figure img{width:100%;border-radius:24px;display:block;box-shadow:var(--ds-shadow-card)}

  .home-encyclo{width:100%;box-sizing:border-box;padding:clamp(56px,8vw,100px) 24px;background:var(--ds-mist,#e9f2f1);border-radius:60px 60px 0 0;margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25));text-align:center}
  .home-encyclo__inner{max-width:800px;margin-inline:auto}
  .home-eyebrow{display:block;margin:0 0 14px;font:700 12px/1.3 Arial,sans-serif;letter-spacing:.14em;text-transform:uppercase;color:#52656b}
  .home-encyclo h2{margin:0 0 20px;font:400 clamp(32px,5vw,56px)/1.05 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .home-encyclo p{margin:0 0 24px;font-size:clamp(17px,1.6vw,21px);line-height:1.6;color:#52656b}
  .home-link{display:inline-flex;align-items:center;gap:8px;color:#164e61;font-weight:700;text-decoration:underline;text-decoration-color:rgba(217,119,6,.6);text-underline-offset:4px}
  .home-link:hover{color:#9a5708}
  .home-coords{margin-top:28px;font:400 15px/1.5 'Tenor Sans',sans-serif;color:#52656b}

  .home-faq{width:100%;box-sizing:border-box;padding:clamp(56px,8vw,100px) 24px;background:#fff;border-radius:60px 60px 0 0;margin-top:calc(-1 * var(--ds-section-overlap,60px));position:relative;z-index:5;box-shadow:var(--ds-shadow-section,0 -7px 20px rgba(135,135,135,.25))}
  .home-faq__inner{max-width:980px;margin-inline:auto}
  .home-faq h2{margin:0 0 32px;font:400 clamp(32px,5vw,56px)/1.05 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .home-faq__list{border-top:1px solid var(--ds-line)}
  .home-faq__list details{border-bottom:1px solid var(--ds-line)}
  .home-faq__list summary{display:flex;align-items:center;justify-content:space-between;padding:22px 0;font:400 18px/1.3 'Tenor Sans',sans-serif;color:var(--ds-ink);cursor:pointer;list-style:none}
  .home-faq__list summary::-webkit-details-marker{display:none}
  .home-faq__list summary span{font:400 24px Arial,sans-serif;color:#d97706;transition:transform .2s}
  .home-faq__list details[open] summary span{transform:rotate(45deg)}
  .home-faq__answer{padding:0 0 22px;color:#52656b;font-size:16px;line-height:1.7}
  .home-faq__cta{margin-top:48px;padding:32px;border-radius:18px;background:var(--ds-paper,#f7faf9);text-align:center}
  .home-faq__cta h3{margin:0 0 8px;font:400 24px/1.2 'Tenor Sans',sans-serif;color:var(--ds-ink)}
  .home-faq__cta p{margin:0 0 18px;color:#52656b}

  @media(max-width:900px){.home-mission__top{grid-template-columns:1fr}.home-mission__grid,.home-services__grid{grid-template-columns:repeat(2,minmax(0,1fr))}.home-charter__inner{grid-template-columns:1fr}}
  @media(max-width:640px){.home-hero,.home-mission,.home-services,.home-put,.home-charter,.home-encyclo,.home-faq{border-radius:36px 36px 0 0;margin-top:calc(-1 * var(--ds-section-overlap-mobile,36px))}.home-mission__grid,.home-services__grid{grid-template-columns:1fr}.home-decor{display:none}}
</style>
