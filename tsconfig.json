{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "~/*": ["src/*"] },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ES2020",
    "types": ["astro/client", "node"]
  },
  "include": ["src", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
